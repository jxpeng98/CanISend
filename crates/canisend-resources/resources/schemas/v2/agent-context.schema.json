{
  "$defs": {
    "ActorKind": {
      "enum": [
        "user",
        "host-agent",
        "configured-provider",
        "system"
      ],
      "type": "string"
    },
    "AgentContextBlocker": {
      "additionalProperties": false,
      "properties": {
        "code": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "subject_id": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "required": [
        "code",
        "description"
      ],
      "type": "object"
    },
    "AgentJobSummary": {
      "additionalProperties": false,
      "properties": {
        "archived": {
          "type": "boolean"
        },
        "id": {
          "type": "string"
        },
        "institution": {
          "type": "string"
        },
        "revision": {
          "format": "uint64",
          "minimum": 0,
          "type": "integer"
        },
        "source_count": {
          "format": "uint64",
          "minimum": 0,
          "type": "integer"
        },
        "title": {
          "type": "string"
        }
      },
      "required": [
        "id",
        "title",
        "institution",
        "revision",
        "source_count",
        "archived"
      ],
      "type": "object"
    },
    "AgentStageCapability": {
      "additionalProperties": false,
      "properties": {
        "execution_modes": {
          "items": {
            "$ref": "#/$defs/ExecutionMode"
          },
          "type": "array"
        },
        "id": {
          "type": "string"
        },
        "status": {
          "$ref": "#/$defs/CapabilityStatus"
        }
      },
      "required": [
        "id",
        "status",
        "execution_modes"
      ],
      "type": "object"
    },
    "AgentWorkspaceSummary": {
      "additionalProperties": false,
      "properties": {
        "active_job_count": {
          "format": "uint64",
          "minimum": 0,
          "type": "integer"
        },
        "active_lead_count": {
          "format": "uint64",
          "minimum": 0,
          "type": "integer"
        },
        "historical_lead_count": {
          "format": "uint64",
          "minimum": 0,
          "type": "integer"
        },
        "open_task_count": {
          "format": "uint64",
          "minimum": 0,
          "type": "integer"
        },
        "stale_artifact_count": {
          "format": "uint64",
          "minimum": 0,
          "type": "integer"
        },
        "total_job_count": {
          "format": "uint64",
          "minimum": 0,
          "type": "integer"
        },
        "workspace_format": {
          "type": "string"
        },
        "workspace_id": {
          "type": "string"
        }
      },
      "required": [
        "workspace_id",
        "workspace_format",
        "active_job_count",
        "total_job_count",
        "active_lead_count",
        "historical_lead_count",
        "open_task_count",
        "stale_artifact_count"
      ],
      "type": "object"
    },
    "CapabilityStatus": {
      "enum": [
        "available",
        "planned"
      ],
      "type": "string"
    },
    "ExecutionMode": {
      "enum": [
        "deterministic",
        "host-agent",
        "configured-provider",
        "user-decision",
        "manual-import"
      ],
      "type": "string"
    },
    "NextAction": {
      "additionalProperties": false,
      "properties": {
        "action": {
          "type": "string"
        },
        "description": {
          "type": "string"
        }
      },
      "required": [
        "action",
        "description"
      ],
      "type": "object"
    },
    "PrivacyClassification": {
      "enum": [
        "public",
        "private-local",
        "provider-bound",
        "secret"
      ],
      "type": "string"
    }
  },
  "$id": "https://schemas.canisend.dev/v2/agent-context.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "active_job_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "actor": {
      "$ref": "#/$defs/ActorKind"
    },
    "blockers": {
      "items": {
        "$ref": "#/$defs/AgentContextBlocker"
      },
      "type": "array"
    },
    "execution_mode": {
      "$ref": "#/$defs/ExecutionMode"
    },
    "next_actions": {
      "items": {
        "$ref": "#/$defs/NextAction"
      },
      "type": "array"
    },
    "privacy": {
      "$ref": "#/$defs/PrivacyClassification"
    },
    "product_version": {
      "type": "string"
    },
    "protocol": {
      "type": "string"
    },
    "resource_format": {
      "type": "string"
    },
    "selected_job": {
      "anyOf": [
        {
          "$ref": "#/$defs/AgentJobSummary"
        },
        {
          "type": "null"
        }
      ]
    },
    "supported_stages": {
      "items": {
        "$ref": "#/$defs/AgentStageCapability"
      },
      "type": "array"
    },
    "workspace": {
      "anyOf": [
        {
          "$ref": "#/$defs/AgentWorkspaceSummary"
        },
        {
          "type": "null"
        }
      ]
    },
    "workspace_format": {
      "type": "string"
    },
    "workspace_id": {
      "type": [
        "string",
        "null"
      ]
    }
  },
  "required": [
    "product_version",
    "protocol",
    "workspace_format",
    "resource_format",
    "actor",
    "execution_mode",
    "supported_stages",
    "blockers",
    "next_actions",
    "privacy"
  ],
  "title": "AgentContextData",
  "type": "object",
  "x-canisend-id": "canisend.agent-context/v2",
  "x-canisend-version": "2.0.0"
}
