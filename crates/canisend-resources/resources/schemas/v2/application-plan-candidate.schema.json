{
  "$defs": {
    "ApplicationDecision": {
      "enum": [
        "apply",
        "hold",
        "skip"
      ],
      "type": "string"
    },
    "ApplicationStrategyRecord": {
      "additionalProperties": false,
      "properties": {
        "positioning": {
          "type": "string"
        },
        "priorities": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "risks": {
          "items": {
            "type": "string"
          },
          "type": "array"
        }
      },
      "required": [
        "positioning",
        "priorities",
        "risks"
      ],
      "type": "object"
    },
    "ArtifactKind": {
      "enum": [
        "source-original",
        "source-normalized-text",
        "parsed-job",
        "evidence-catalog",
        "criteria",
        "evidence-matches",
        "application-plan",
        "cover-letter",
        "research-statement",
        "teaching-statement",
        "cv",
        "document-set",
        "review-findings",
        "package-manifest",
        "export-manifest",
        "typst-source",
        "pdf",
        "render-manifest"
      ],
      "type": "string"
    },
    "ArtifactReference": {
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string"
        },
        "kind": {
          "$ref": "#/$defs/ArtifactKind"
        },
        "revision": {
          "format": "uint64",
          "minimum": 0,
          "type": "integer"
        },
        "sha256": {
          "type": "string"
        }
      },
      "required": [
        "kind",
        "id",
        "revision",
        "sha256"
      ],
      "type": "object"
    },
    "CriterionRevisionReference": {
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string"
        },
        "revision": {
          "format": "uint64",
          "minimum": 0,
          "type": "integer"
        }
      },
      "required": [
        "id",
        "revision"
      ],
      "type": "object"
    },
    "DocumentKind": {
      "enum": [
        "cover-letter",
        "research-statement",
        "teaching-statement",
        "cv"
      ],
      "type": "string"
    },
    "DocumentPlanCandidateRecord": {
      "additionalProperties": false,
      "properties": {
        "constraints": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "executor": {
          "anyOf": [
            {
              "$ref": "#/$defs/ExecutionMode"
            },
            {
              "type": "null"
            }
          ]
        },
        "kind": {
          "$ref": "#/$defs/DocumentKind"
        },
        "rationale": {
          "type": "string"
        },
        "requirement": {
          "$ref": "#/$defs/DocumentRequirement"
        }
      },
      "required": [
        "kind",
        "requirement",
        "rationale",
        "constraints"
      ],
      "type": "object"
    },
    "DocumentRequirement": {
      "enum": [
        "required",
        "optional",
        "omitted"
      ],
      "type": "string"
    },
    "ExecutionMode": {
      "enum": [
        "deterministic",
        "host-agent",
        "configured-provider",
        "user-decision",
        "manual-import"
      ],
      "type": "string"
    },
    "PlanBlockerRecord": {
      "additionalProperties": false,
      "properties": {
        "code": {
          "type": "string"
        },
        "criterion": {
          "$ref": "#/$defs/CriterionRevisionReference"
        },
        "description": {
          "type": "string"
        },
        "severity": {
          "$ref": "#/$defs/PlanBlockerSeverity"
        }
      },
      "required": [
        "code",
        "criterion",
        "severity",
        "description"
      ],
      "type": "object"
    },
    "PlanBlockerSeverity": {
      "enum": [
        "blocking",
        "warning"
      ],
      "type": "string"
    }
  },
  "$id": "https://schemas.canisend.dev/v2/application-plan-candidate.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "blockers": {
      "items": {
        "$ref": "#/$defs/PlanBlockerRecord"
      },
      "type": "array"
    },
    "decision": {
      "$ref": "#/$defs/ApplicationDecision"
    },
    "documents": {
      "items": {
        "$ref": "#/$defs/DocumentPlanCandidateRecord"
      },
      "type": "array"
    },
    "job_id": {
      "type": "string"
    },
    "matches_artifact": {
      "$ref": "#/$defs/ArtifactReference"
    },
    "strategy": {
      "$ref": "#/$defs/ApplicationStrategyRecord"
    }
  },
  "required": [
    "job_id",
    "matches_artifact",
    "decision",
    "strategy",
    "documents",
    "blockers"
  ],
  "title": "ApplicationPlanCandidate",
  "type": "object",
  "x-canisend-id": "canisend.application-plan-candidate/v2",
  "x-canisend-version": "2.0.0"
}
