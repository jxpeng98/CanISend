{
  "$defs": {
    "AgentStageCapability": {
      "additionalProperties": false,
      "properties": {
        "execution_modes": {
          "items": {
            "$ref": "#/$defs/ExecutionMode"
          },
          "type": "array"
        },
        "id": {
          "type": "string"
        },
        "status": {
          "$ref": "#/$defs/CapabilityStatus"
        }
      },
      "required": [
        "id",
        "status",
        "execution_modes"
      ],
      "type": "object"
    },
    "Capability": {
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string"
        },
        "status": {
          "$ref": "#/$defs/CapabilityStatus"
        },
        "version": {
          "type": "string"
        }
      },
      "required": [
        "id",
        "version",
        "status"
      ],
      "type": "object"
    },
    "CapabilityStatus": {
      "enum": [
        "available",
        "planned"
      ],
      "type": "string"
    },
    "DiscoveryAdapterCapabilities": {
      "additionalProperties": false,
      "properties": {
        "kind": {
          "$ref": "#/$defs/DiscoverySourceKind"
        },
        "max_items_per_refresh": {
          "format": "uint32",
          "minimum": 0,
          "type": "integer"
        },
        "network": {
          "type": "boolean"
        },
        "preserves_removed": {
          "type": "boolean"
        },
        "supports_cursor": {
          "type": "boolean"
        }
      },
      "required": [
        "kind",
        "network",
        "supports_cursor",
        "preserves_removed",
        "max_items_per_refresh"
      ],
      "type": "object"
    },
    "DiscoverySourceKind": {
      "enum": [
        "csv",
        "json",
        "host-agent",
        "rss-atom",
        "jobs-ac-uk",
        "greenhouse",
        "lever"
      ],
      "type": "string"
    },
    "ExecutionMode": {
      "enum": [
        "deterministic",
        "host-agent",
        "configured-provider",
        "user-decision",
        "manual-import"
      ],
      "type": "string"
    }
  },
  "$id": "https://schemas.canisend.dev/v2/capabilities.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "capabilities": {
      "items": {
        "$ref": "#/$defs/Capability"
      },
      "type": "array"
    },
    "discovery_adapters": {
      "items": {
        "$ref": "#/$defs/DiscoveryAdapterCapabilities"
      },
      "type": "array"
    },
    "error_codes": {
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "product_version": {
      "type": "string"
    },
    "protocol": {
      "type": "string"
    },
    "resource_format": {
      "type": "string"
    },
    "stages": {
      "items": {
        "$ref": "#/$defs/AgentStageCapability"
      },
      "type": "array"
    },
    "workspace_format": {
      "type": "string"
    }
  },
  "required": [
    "product_version",
    "protocol",
    "workspace_format",
    "resource_format",
    "capabilities",
    "stages",
    "discovery_adapters",
    "error_codes"
  ],
  "title": "CapabilitiesData",
  "type": "object",
  "x-canisend-id": "canisend.capabilities/v2",
  "x-canisend-version": "2.0.0"
}
