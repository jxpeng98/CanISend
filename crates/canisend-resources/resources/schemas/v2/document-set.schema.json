{
  "$defs": {
    "ArtifactKind": {
      "enum": [
        "source-original",
        "source-normalized-text",
        "parsed-job",
        "evidence-catalog",
        "criteria",
        "evidence-matches",
        "application-plan",
        "cover-letter",
        "research-statement",
        "teaching-statement",
        "cv",
        "document-set",
        "review-findings",
        "package-manifest",
        "typst-source",
        "pdf"
      ],
      "type": "string"
    },
    "ArtifactReference": {
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string"
        },
        "kind": {
          "$ref": "#/$defs/ArtifactKind"
        },
        "revision": {
          "format": "uint64",
          "minimum": 0,
          "type": "integer"
        },
        "sha256": {
          "type": "string"
        }
      },
      "required": [
        "kind",
        "id",
        "revision",
        "sha256"
      ],
      "type": "object"
    }
  },
  "$id": "https://schemas.canisend.dev/v2/document-set.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "documents": {
      "items": {
        "$ref": "#/$defs/ArtifactReference"
      },
      "type": "array"
    },
    "id": {
      "type": "string"
    },
    "job_id": {
      "type": "string"
    },
    "plan_artifact": {
      "$ref": "#/$defs/ArtifactReference"
    },
    "revision": {
      "format": "uint64",
      "minimum": 0,
      "type": "integer"
    }
  },
  "required": [
    "id",
    "job_id",
    "plan_artifact",
    "documents",
    "revision"
  ],
  "title": "DocumentSetRecord",
  "type": "object",
  "x-canisend-id": "canisend.document-set/v2",
  "x-canisend-version": "2.0.0"
}
