{
  "$defs": {
    "ActorKind": {
      "enum": [
        "user",
        "host-agent",
        "configured-provider",
        "system"
      ],
      "type": "string"
    },
    "ArtifactKind": {
      "enum": [
        "source-original",
        "source-normalized-text",
        "parsed-job",
        "evidence-catalog",
        "criteria",
        "evidence-matches",
        "application-plan",
        "cover-letter",
        "research-statement",
        "teaching-statement",
        "cv",
        "document-set",
        "review-findings",
        "package-manifest",
        "export-manifest",
        "typst-source",
        "pdf"
      ],
      "type": "string"
    },
    "ArtifactReference": {
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string"
        },
        "kind": {
          "$ref": "#/$defs/ArtifactKind"
        },
        "revision": {
          "format": "uint64",
          "minimum": 0,
          "type": "integer"
        },
        "sha256": {
          "type": "string"
        }
      },
      "required": [
        "kind",
        "id",
        "revision",
        "sha256"
      ],
      "type": "object"
    },
    "CitationTarget": {
      "oneOf": [
        {
          "additionalProperties": false,
          "properties": {
            "evidence": {
              "$ref": "#/$defs/EvidenceRevisionReference"
            },
            "kind": {
              "const": "evidence",
              "type": "string"
            }
          },
          "required": [
            "kind",
            "evidence"
          ],
          "type": "object"
        },
        {
          "additionalProperties": false,
          "properties": {
            "criterion": {
              "$ref": "#/$defs/CriterionRevisionReference"
            },
            "kind": {
              "const": "criterion",
              "type": "string"
            }
          },
          "required": [
            "kind",
            "criterion"
          ],
          "type": "object"
        }
      ]
    },
    "ClaimClassification": {
      "enum": [
        "applicant-fact",
        "job-requirement",
        "user-intent",
        "non-factual"
      ],
      "type": "string"
    },
    "CriterionRevisionReference": {
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string"
        },
        "revision": {
          "format": "uint64",
          "minimum": 0,
          "type": "integer"
        }
      },
      "required": [
        "id",
        "revision"
      ],
      "type": "object"
    },
    "DocumentCitationRecord": {
      "additionalProperties": false,
      "properties": {
        "purpose": {
          "type": "string"
        },
        "target": {
          "$ref": "#/$defs/CitationTarget"
        }
      },
      "required": [
        "target",
        "purpose"
      ],
      "type": "object"
    },
    "DocumentClaimRecord": {
      "additionalProperties": false,
      "properties": {
        "citations": {
          "items": {
            "$ref": "#/$defs/DocumentCitationRecord"
          },
          "type": "array"
        },
        "classification": {
          "$ref": "#/$defs/ClaimClassification"
        },
        "id": {
          "type": "string"
        },
        "revision": {
          "format": "uint64",
          "minimum": 0,
          "type": "integer"
        },
        "text": {
          "type": "string"
        }
      },
      "required": [
        "id",
        "text",
        "classification",
        "citations",
        "revision"
      ],
      "type": "object"
    },
    "DocumentGenerationMetadata": {
      "additionalProperties": false,
      "properties": {
        "actor": {
          "$ref": "#/$defs/ActorKind"
        },
        "created_at": {
          "type": "string"
        },
        "execution_mode": {
          "$ref": "#/$defs/ExecutionMode"
        },
        "prompt_resource_id": {
          "type": "string"
        },
        "task_id": {
          "type": "string"
        }
      },
      "required": [
        "actor",
        "execution_mode",
        "task_id",
        "prompt_resource_id",
        "created_at"
      ],
      "type": "object"
    },
    "DocumentKind": {
      "enum": [
        "cover-letter",
        "research-statement",
        "teaching-statement",
        "cv"
      ],
      "type": "string"
    },
    "DocumentPlaceholderRecord": {
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string"
        },
        "instruction": {
          "type": "string"
        },
        "key": {
          "type": "string"
        },
        "required": {
          "type": "boolean"
        },
        "resolution": {
          "type": [
            "string",
            "null"
          ]
        },
        "revision": {
          "format": "uint64",
          "minimum": 0,
          "type": "integer"
        }
      },
      "required": [
        "id",
        "key",
        "instruction",
        "required",
        "revision"
      ],
      "type": "object"
    },
    "DocumentSectionKind": {
      "enum": [
        "opening",
        "fit",
        "research",
        "teaching",
        "service",
        "experience",
        "education",
        "publications",
        "skills",
        "closing",
        "other"
      ],
      "type": "string"
    },
    "DocumentSectionRecord": {
      "additionalProperties": false,
      "properties": {
        "body": {
          "type": "string"
        },
        "claims": {
          "items": {
            "$ref": "#/$defs/DocumentClaimRecord"
          },
          "type": "array"
        },
        "heading": {
          "type": [
            "string",
            "null"
          ]
        },
        "id": {
          "type": "string"
        },
        "kind": {
          "$ref": "#/$defs/DocumentSectionKind"
        },
        "revision": {
          "format": "uint64",
          "minimum": 0,
          "type": "integer"
        }
      },
      "required": [
        "id",
        "kind",
        "body",
        "claims",
        "revision"
      ],
      "type": "object"
    },
    "EvidenceRevisionReference": {
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string"
        },
        "revision": {
          "format": "uint64",
          "minimum": 0,
          "type": "integer"
        }
      },
      "required": [
        "id",
        "revision"
      ],
      "type": "object"
    },
    "ExecutionMode": {
      "enum": [
        "deterministic",
        "host-agent",
        "configured-provider",
        "user-decision",
        "manual-import"
      ],
      "type": "string"
    },
    "PlannedDocumentRevisionReference": {
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string"
        },
        "revision": {
          "format": "uint64",
          "minimum": 0,
          "type": "integer"
        }
      },
      "required": [
        "id",
        "revision"
      ],
      "type": "object"
    }
  },
  "$id": "https://schemas.canisend.dev/v2/document.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "generation": {
      "$ref": "#/$defs/DocumentGenerationMetadata"
    },
    "id": {
      "type": "string"
    },
    "job_id": {
      "type": "string"
    },
    "kind": {
      "$ref": "#/$defs/DocumentKind"
    },
    "placeholders": {
      "items": {
        "$ref": "#/$defs/DocumentPlaceholderRecord"
      },
      "type": "array"
    },
    "plan_artifact": {
      "$ref": "#/$defs/ArtifactReference"
    },
    "planned_document": {
      "$ref": "#/$defs/PlannedDocumentRevisionReference"
    },
    "revision": {
      "format": "uint64",
      "minimum": 0,
      "type": "integer"
    },
    "sections": {
      "items": {
        "$ref": "#/$defs/DocumentSectionRecord"
      },
      "type": "array"
    },
    "title": {
      "type": "string"
    }
  },
  "required": [
    "id",
    "job_id",
    "plan_artifact",
    "planned_document",
    "kind",
    "title",
    "sections",
    "placeholders",
    "generation",
    "revision"
  ],
  "title": "DocumentRecord",
  "type": "object",
  "x-canisend-id": "canisend.document/v2",
  "x-canisend-version": "2.0.0"
}
