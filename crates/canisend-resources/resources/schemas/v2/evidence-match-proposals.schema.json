{
  "$defs": {
    "ArtifactKind": {
      "enum": [
        "source-original",
        "source-normalized-text",
        "parsed-job",
        "evidence-catalog",
        "criteria",
        "evidence-matches",
        "application-plan",
        "cover-letter",
        "research-statement",
        "teaching-statement",
        "cv",
        "document-set",
        "review-findings",
        "package-manifest",
        "export-manifest",
        "typst-source",
        "pdf"
      ],
      "type": "string"
    },
    "ArtifactReference": {
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string"
        },
        "kind": {
          "$ref": "#/$defs/ArtifactKind"
        },
        "revision": {
          "format": "uint64",
          "minimum": 0,
          "type": "integer"
        },
        "sha256": {
          "type": "string"
        }
      },
      "required": [
        "kind",
        "id",
        "revision",
        "sha256"
      ],
      "type": "object"
    },
    "CriterionRevisionReference": {
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string"
        },
        "revision": {
          "format": "uint64",
          "minimum": 0,
          "type": "integer"
        }
      },
      "required": [
        "id",
        "revision"
      ],
      "type": "object"
    },
    "EvidenceMatchProposalRecord": {
      "additionalProperties": false,
      "properties": {
        "criterion": {
          "$ref": "#/$defs/CriterionRevisionReference"
        },
        "evidence": {
          "items": {
            "$ref": "#/$defs/EvidenceRevisionReference"
          },
          "type": "array"
        },
        "gap": {
          "type": [
            "string",
            "null"
          ]
        },
        "prohibited_claims": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "rationale": {
          "type": "string"
        },
        "strength": {
          "$ref": "#/$defs/MatchStrength"
        }
      },
      "required": [
        "criterion",
        "evidence",
        "strength",
        "rationale",
        "prohibited_claims"
      ],
      "type": "object"
    },
    "EvidenceRevisionReference": {
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string"
        },
        "revision": {
          "format": "uint64",
          "minimum": 0,
          "type": "integer"
        }
      },
      "required": [
        "id",
        "revision"
      ],
      "type": "object"
    },
    "MatchStrength": {
      "enum": [
        "strong",
        "partial",
        "gap",
        "unknown"
      ],
      "type": "string"
    }
  },
  "$id": "https://schemas.canisend.dev/v2/evidence-match-proposals.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "criteria_artifact": {
      "$ref": "#/$defs/ArtifactReference"
    },
    "evidence_artifact": {
      "$ref": "#/$defs/ArtifactReference"
    },
    "job_id": {
      "type": "string"
    },
    "proposals": {
      "items": {
        "$ref": "#/$defs/EvidenceMatchProposalRecord"
      },
      "type": "array"
    }
  },
  "required": [
    "job_id",
    "criteria_artifact",
    "evidence_artifact",
    "proposals"
  ],
  "title": "EvidenceMatchProposalSet",
  "type": "object",
  "x-canisend-id": "canisend.evidence-match-proposals/v2",
  "x-canisend-version": "2.0.0"
}
