{
  "$defs": {
    "CriterionRevisionReference": {
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string"
        },
        "revision": {
          "format": "uint64",
          "minimum": 0,
          "type": "integer"
        }
      },
      "required": [
        "id",
        "revision"
      ],
      "type": "object"
    },
    "EvidenceRevisionReference": {
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string"
        },
        "revision": {
          "format": "uint64",
          "minimum": 0,
          "type": "integer"
        }
      },
      "required": [
        "id",
        "revision"
      ],
      "type": "object"
    },
    "MatchStrength": {
      "enum": [
        "strong",
        "partial",
        "gap",
        "unknown"
      ],
      "type": "string"
    }
  },
  "$id": "https://schemas.canisend.dev/v2/evidence-match.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "criterion": {
      "$ref": "#/$defs/CriterionRevisionReference"
    },
    "evidence": {
      "items": {
        "$ref": "#/$defs/EvidenceRevisionReference"
      },
      "type": "array"
    },
    "gap": {
      "type": [
        "string",
        "null"
      ]
    },
    "id": {
      "type": "string"
    },
    "prohibited_claims": {
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "rationale": {
      "type": "string"
    },
    "revision": {
      "format": "uint64",
      "minimum": 0,
      "type": "integer"
    },
    "strength": {
      "$ref": "#/$defs/MatchStrength"
    }
  },
  "required": [
    "id",
    "criterion",
    "evidence",
    "strength",
    "rationale",
    "prohibited_claims",
    "revision"
  ],
  "title": "EvidenceMatchRecord",
  "type": "object",
  "x-canisend-id": "canisend.evidence-match/v2",
  "x-canisend-version": "2.0.0"
}
