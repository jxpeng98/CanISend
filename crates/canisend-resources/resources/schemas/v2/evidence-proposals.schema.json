{
  "$defs": {
    "ArtifactKind": {
      "enum": [
        "source-original",
        "source-normalized-text",
        "parsed-job",
        "evidence-catalog",
        "criteria",
        "evidence-matches",
        "application-plan",
        "cover-letter",
        "research-statement",
        "teaching-statement",
        "cv",
        "document-set",
        "review-findings",
        "package-manifest",
        "export-manifest",
        "typst-source",
        "pdf",
        "render-manifest"
      ],
      "type": "string"
    },
    "ArtifactReference": {
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string"
        },
        "kind": {
          "$ref": "#/$defs/ArtifactKind"
        },
        "revision": {
          "format": "uint64",
          "minimum": 0,
          "type": "integer"
        },
        "sha256": {
          "type": "string"
        }
      },
      "required": [
        "kind",
        "id",
        "revision",
        "sha256"
      ],
      "type": "object"
    },
    "EvidenceKind": {
      "enum": [
        "qualification",
        "teaching",
        "research",
        "communication",
        "leadership",
        "service",
        "employment",
        "other"
      ],
      "type": "string"
    },
    "EvidenceProposalRecord": {
      "additionalProperties": false,
      "properties": {
        "kind": {
          "$ref": "#/$defs/EvidenceKind"
        },
        "sensitivity": {
          "$ref": "#/$defs/PrivacyClassification"
        },
        "source_quote": {
          "type": "string"
        },
        "source_span": {
          "$ref": "#/$defs/SourceTextSpan"
        },
        "summary": {
          "type": "string"
        }
      },
      "required": [
        "kind",
        "summary",
        "source_quote",
        "source_span",
        "sensitivity"
      ],
      "type": "object"
    },
    "PrivacyClassification": {
      "enum": [
        "public",
        "private-local",
        "provider-bound",
        "secret"
      ],
      "type": "string"
    },
    "SourceTextSpan": {
      "additionalProperties": false,
      "properties": {
        "end_byte": {
          "format": "uint64",
          "minimum": 0,
          "type": "integer"
        },
        "source": {
          "$ref": "#/$defs/ArtifactReference"
        },
        "start_byte": {
          "format": "uint64",
          "minimum": 0,
          "type": "integer"
        }
      },
      "required": [
        "source",
        "start_byte",
        "end_byte"
      ],
      "type": "object"
    }
  },
  "$id": "https://schemas.canisend.dev/v2/evidence-proposals.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "profile_revision": {
      "format": "uint64",
      "minimum": 0,
      "type": "integer"
    },
    "proposals": {
      "items": {
        "$ref": "#/$defs/EvidenceProposalRecord"
      },
      "type": "array"
    }
  },
  "required": [
    "profile_revision",
    "proposals"
  ],
  "title": "EvidenceProposalSet",
  "type": "object",
  "x-canisend-id": "canisend.evidence-proposals/v2",
  "x-canisend-version": "2.0.0"
}
