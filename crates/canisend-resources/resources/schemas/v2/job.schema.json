    "title",
    "institution",
    "source_ids",
    "created_at",
    "revision",
    "archived"
  ],
  "title": "JobRecord",
  "type": "object",
  "x-canisend-id": "canisend.job/v2",
  "x-canisend-version": "2.0.0"
