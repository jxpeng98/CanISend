{
  "$defs": {
    "ArtifactKind": {
      "enum": [
        "source-original",
        "source-normalized-text",
        "parsed-job",
        "evidence-catalog",
        "criteria",
        "evidence-matches",
        "application-plan",
        "cover-letter",
        "research-statement",
        "teaching-statement",
        "cv",
        "document-set",
        "review-findings",
        "package-manifest",
        "export-manifest",
        "typst-source",
        "pdf"
      ],
      "type": "string"
    },
    "ArtifactReference": {
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string"
        },
        "kind": {
          "$ref": "#/$defs/ArtifactKind"
        },
        "revision": {
          "format": "uint64",
          "minimum": 0,
          "type": "integer"
        },
        "sha256": {
          "type": "string"
        }
      },
      "required": [
        "kind",
        "id",
        "revision",
        "sha256"
      ],
      "type": "object"
    },
    "ProjectionEditStatus": {
      "enum": [
        "current",
        "edited",
        "missing",
        "repair-required"
      ],
      "type": "string"
    },
    "ProjectionKind": {
      "enum": [
        "markdown",
        "structured-json",
        "package-manifest-json"
      ],
      "type": "string"
    },
    "ProjectionRecord": {
      "additionalProperties": false,
      "properties": {
        "edit_status": {
          "$ref": "#/$defs/ProjectionEditStatus"
        },
        "generated_sha256": {
          "type": "string"
        },
        "kind": {
          "$ref": "#/$defs/ProjectionKind"
        },
        "observed_sha256": {
          "type": [
            "string",
            "null"
          ]
        },
        "relative_path": {
          "type": "string"
        },
        "source_artifact": {
          "$ref": "#/$defs/ArtifactReference"
        },
        "updated_at": {
          "type": "string"
        }
      },
      "required": [
        "source_artifact",
        "relative_path",
        "kind",
        "generated_sha256",
        "edit_status",
        "updated_at"
      ],
      "type": "object"
    }
  },
  "$id": "https://schemas.canisend.dev/v2/package-export-manifest.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "exported_at": {
      "type": "string"
    },
    "id": {
      "type": "string"
    },
    "job_id": {
      "type": "string"
    },
    "package_artifact": {
      "$ref": "#/$defs/ArtifactReference"
    },
    "projections": {
      "items": {
        "$ref": "#/$defs/ProjectionRecord"
      },
      "type": "array"
    },
    "revision": {
      "format": "uint64",
      "minimum": 0,
      "type": "integer"
    },
    "submission_performed": {
      "type": "boolean"
    }
  },
  "required": [
    "id",
    "job_id",
    "package_artifact",
    "projections",
    "exported_at",
    "submission_performed",
    "revision"
  ],
  "title": "PackageExportManifestRecord",
  "type": "object",
  "x-canisend-id": "canisend.package-export-manifest/v2",
  "x-canisend-version": "2.0.0"
}
