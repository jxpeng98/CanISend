{
  "$defs": {
    "ArtifactKind": {
      "enum": [
        "source-original",
        "source-normalized-text",
        "parsed-job",
        "evidence-catalog",
        "criteria",
        "evidence-matches",
        "application-plan",
        "cover-letter",
        "research-statement",
        "teaching-statement",
        "cv",
        "document-set",
        "review-findings",
        "package-manifest",
        "typst-source",
        "pdf"
      ],
      "type": "string"
    },
    "ArtifactReference": {
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string"
        },
        "kind": {
          "$ref": "#/$defs/ArtifactKind"
        },
        "revision": {
          "format": "uint64",
          "minimum": 0,
          "type": "integer"
        },
        "sha256": {
          "type": "string"
        }
      },
      "required": [
        "kind",
        "id",
        "revision",
        "sha256"
      ],
      "type": "object"
    },
    "DocumentKind": {
      "enum": [
        "cover-letter",
        "research-statement",
        "teaching-statement",
        "cv"
      ],
      "type": "string"
    },
    "ReadinessReasonCode": {
      "enum": [
        "missing-required-document",
        "stale-document",
        "document-plan-mismatch",
        "review-document-set-mismatch",
        "open-deterministic-finding",
        "pending-human-finding",
        "mixed-plan-revision",
        "mixed-evidence-revision",
        "mixed-profile-revision"
      ],
      "type": "string"
    },
    "ReadinessReasonRecord": {
      "additionalProperties": false,
      "properties": {
        "artifact": {
          "anyOf": [
            {
              "$ref": "#/$defs/ArtifactReference"
            },
            {
              "type": "null"
            }
          ]
        },
        "code": {
          "$ref": "#/$defs/ReadinessReasonCode"
        },
        "document_kind": {
          "anyOf": [
            {
              "$ref": "#/$defs/DocumentKind"
            },
            {
              "type": "null"
            }
          ]
        },
        "finding_id": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "required": [
        "code"
      ],
      "type": "object"
    },
    "ReadinessRecord": {
      "additionalProperties": false,
      "properties": {
        "checked_at": {
          "type": "string"
        },
        "job_id": {
          "type": "string"
        },
        "reasons": {
          "items": {
            "$ref": "#/$defs/ReadinessReasonRecord"
          },
          "type": "array"
        },
        "state": {
          "$ref": "#/$defs/ReadinessState"
        }
      },
      "required": [
        "job_id",
        "state",
        "reasons",
        "checked_at"
      ],
      "type": "object"
    },
    "ReadinessState": {
      "enum": [
        "blocked",
        "needs-review",
        "ready-to-export",
        "exported"
      ],
      "type": "string"
    }
  },
  "$id": "https://schemas.canisend.dev/v2/package-manifest.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "document_set_artifact": {
      "$ref": "#/$defs/ArtifactReference"
    },
    "documents": {
      "items": {
        "$ref": "#/$defs/ArtifactReference"
      },
      "type": "array"
    },
    "evidence_artifact": {
      "$ref": "#/$defs/ArtifactReference"
    },
    "id": {
      "type": "string"
    },
    "job_id": {
      "type": "string"
    },
    "plan_artifact": {
      "$ref": "#/$defs/ArtifactReference"
    },
    "profile_revision": {
      "format": "uint64",
      "minimum": 0,
      "type": "integer"
    },
    "readiness": {
      "$ref": "#/$defs/ReadinessRecord"
    },
    "review_artifact": {
      "$ref": "#/$defs/ArtifactReference"
    },
    "revision": {
      "format": "uint64",
      "minimum": 0,
      "type": "integer"
    },
    "submission_performed": {
      "type": "boolean"
    }
  },
  "required": [
    "id",
    "job_id",
    "plan_artifact",
    "evidence_artifact",
    "profile_revision",
    "document_set_artifact",
    "documents",
    "review_artifact",
    "readiness",
    "submission_performed",
    "revision"
  ],
  "title": "PackageManifestRecord",
  "type": "object",
  "x-canisend-id": "canisend.package-manifest/v2",
  "x-canisend-version": "2.0.0"
}
