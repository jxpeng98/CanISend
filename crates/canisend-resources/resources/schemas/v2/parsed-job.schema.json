{
  "$defs": {
    "ArtifactKind": {
      "enum": [
        "source-original",
        "source-normalized-text",
        "parsed-job",
        "evidence-catalog",
        "criteria",
        "evidence-matches",
        "application-plan",
        "cover-letter",
        "research-statement",
        "teaching-statement",
        "cv",
        "document-set",
        "review-findings",
        "package-manifest",
        "export-manifest",
        "typst-source",
        "pdf"
      ],
      "type": "string"
    },
    "ArtifactReference": {
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string"
        },
        "kind": {
          "$ref": "#/$defs/ArtifactKind"
        },
        "revision": {
          "format": "uint64",
          "minimum": 0,
          "type": "integer"
        },
        "sha256": {
          "type": "string"
        }
      },
      "required": [
        "kind",
        "id",
        "revision",
        "sha256"
      ],
      "type": "object"
    },
    "CriterionImportance": {
      "enum": [
        "essential",
        "desirable",
        "informational"
      ],
      "type": "string"
    },
    "CriterionRecord": {
      "additionalProperties": false,
      "properties": {
        "confidence_milli": {
          "format": "uint16",
          "maximum": 65535,
          "minimum": 0,
          "type": "integer"
        },
        "confirmed": {
          "type": "boolean"
        },
        "id": {
          "type": "string"
        },
        "importance": {
          "$ref": "#/$defs/CriterionImportance"
        },
        "job_id": {
          "type": "string"
        },
        "kind": {
          "$ref": "#/$defs/EvidenceKind"
        },
        "requirement": {
          "type": "string"
        },
        "revision": {
          "format": "uint64",
          "minimum": 0,
          "type": "integer"
        },
        "source_quote": {
          "type": "string"
        },
        "source_span": {
          "$ref": "#/$defs/SourceTextSpan"
        }
      },
      "required": [
        "id",
        "job_id",
        "kind",
        "requirement",
        "importance",
        "source_quote",
        "source_span",
        "confidence_milli",
        "confirmed",
        "revision"
      ],
      "type": "object"
    },
    "EvidenceKind": {
      "enum": [
        "qualification",
        "teaching",
        "research",
        "communication",
        "leadership",
        "service",
        "employment",
        "other"
      ],
      "type": "string"
    },
    "SourceTextSpan": {
      "additionalProperties": false,
      "properties": {
        "end_byte": {
          "format": "uint64",
          "minimum": 0,
          "type": "integer"
        },
        "source": {
          "$ref": "#/$defs/ArtifactReference"
        },
        "start_byte": {
          "format": "uint64",
          "minimum": 0,
          "type": "integer"
        }
      },
      "required": [
        "source",
        "start_byte",
        "end_byte"
      ],
      "type": "object"
    }
  },
  "$id": "https://schemas.canisend.dev/v2/parsed-job.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "criteria": {
      "items": {
        "$ref": "#/$defs/CriterionRecord"
      },
      "type": "array"
    },
    "id": {
      "type": "string"
    },
    "institution": {
      "type": "string"
    },
    "job_id": {
      "type": "string"
    },
    "responsibilities": {
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "revision": {
      "format": "uint64",
      "minimum": 0,
      "type": "integer"
    },
    "summary": {
      "type": "string"
    },
    "title": {
      "type": "string"
    }
  },
  "required": [
    "id",
    "job_id",
    "title",
    "institution",
    "summary",
    "responsibilities",
    "criteria",
    "revision"
  ],
  "title": "ParsedJobRecord",
  "type": "object",
  "x-canisend-id": "canisend.parsed-job/v2",
  "x-canisend-version": "2.0.0"
}
