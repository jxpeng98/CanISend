{
  "$defs": {
    "ArtifactKind": {
      "enum": [
        "source-original",
        "source-normalized-text",
        "parsed-job",
        "evidence-catalog",
        "criteria",
        "evidence-matches",
        "application-plan",
        "cover-letter",
        "research-statement",
        "teaching-statement",
        "cv",
        "document-set",
        "review-findings",
        "package-manifest",
        "export-manifest",
        "typst-source",
        "pdf",
        "render-manifest"
      ],
      "type": "string"
    },
    "ArtifactReference": {
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string"
        },
        "kind": {
          "$ref": "#/$defs/ArtifactKind"
        },
        "revision": {
          "format": "uint64",
          "minimum": 0,
          "type": "integer"
        },
        "sha256": {
          "type": "string"
        }
      },
      "required": [
        "kind",
        "id",
        "revision",
        "sha256"
      ],
      "type": "object"
    },
    "DocumentKind": {
      "enum": [
        "cover-letter",
        "research-statement",
        "teaching-statement",
        "cv"
      ],
      "type": "string"
    }
  },
  "$id": "https://schemas.canisend.dev/v2/rendered-document.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "byte_count": {
      "format": "uint64",
      "minimum": 0,
      "type": "integer"
    },
    "document_artifact": {
      "$ref": "#/$defs/ArtifactReference"
    },
    "elapsed_millis": {
      "format": "uint64",
      "minimum": 0,
      "type": "integer"
    },
    "kind": {
      "$ref": "#/$defs/DocumentKind"
    },
    "page_count": {
      "format": "uint32",
      "minimum": 0,
      "type": "integer"
    },
    "pdf_artifact": {
      "$ref": "#/$defs/ArtifactReference"
    },
    "typst_artifact": {
      "$ref": "#/$defs/ArtifactReference"
    },
    "warning_count": {
      "format": "uint32",
      "minimum": 0,
      "type": "integer"
    }
  },
  "required": [
    "kind",
    "document_artifact",
    "typst_artifact",
    "pdf_artifact",
    "page_count",
    "byte_count",
    "warning_count",
    "elapsed_millis"
  ],
  "title": "RenderedDocumentRecord",
  "type": "object",
  "x-canisend-id": "canisend.rendered-document/v2",
  "x-canisend-version": "2.0.0"
}
