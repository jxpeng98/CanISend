{
  "$defs": {
    "ActorKind": {
      "enum": [
        "user",
        "host-agent",
        "configured-provider",
        "system"
      ],
      "type": "string"
    },
    "ArtifactKind": {
      "enum": [
        "source-original",
        "source-normalized-text",
        "parsed-job",
        "evidence-catalog",
        "criteria",
        "evidence-matches",
        "application-plan",
        "cover-letter",
        "research-statement",
        "teaching-statement",
        "cv",
        "document-set",
        "review-findings",
        "package-manifest",
        "export-manifest",
        "typst-source",
        "pdf"
      ],
      "type": "string"
    },
    "ArtifactReference": {
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string"
        },
        "kind": {
          "$ref": "#/$defs/ArtifactKind"
        },
        "revision": {
          "format": "uint64",
          "minimum": 0,
          "type": "integer"
        },
        "sha256": {
          "type": "string"
        }
      },
      "required": [
        "kind",
        "id",
        "revision",
        "sha256"
      ],
      "type": "object"
    },
    "FindingAuthority": {
      "enum": [
        "deterministic",
        "human-review"
      ],
      "type": "string"
    },
    "FindingCategory": {
      "enum": [
        "citation-invalid",
        "unclaimed-content",
        "prohibited-claim",
        "unresolved-placeholder",
        "cross-document-inconsistency",
        "human-judgement"
      ],
      "type": "string"
    },
    "FindingRecord": {
      "additionalProperties": false,
      "properties": {
        "authority": {
          "$ref": "#/$defs/FindingAuthority"
        },
        "category": {
          "$ref": "#/$defs/FindingCategory"
        },
        "code": {
          "type": "string"
        },
        "decided_at": {
          "type": [
            "string",
            "null"
          ]
        },
        "decided_by": {
          "anyOf": [
            {
              "$ref": "#/$defs/ActorKind"
            },
            {
              "type": "null"
            }
          ]
        },
        "disposition_reason": {
          "type": [
            "string",
            "null"
          ]
        },
        "id": {
          "type": "string"
        },
        "message": {
          "type": "string"
        },
        "related_targets": {
          "items": {
            "$ref": "#/$defs/FindingTarget"
          },
          "type": "array"
        },
        "revision": {
          "format": "uint64",
          "minimum": 0,
          "type": "integer"
        },
        "severity": {
          "$ref": "#/$defs/FindingSeverity"
        },
        "status": {
          "$ref": "#/$defs/FindingStatus"
        },
        "suggested_resolution": {
          "type": [
            "string",
            "null"
          ]
        },
        "target": {
          "$ref": "#/$defs/FindingTarget"
        }
      },
      "required": [
        "id",
        "code",
        "category",
        "severity",
        "authority",
        "message",
        "target",
        "related_targets",
        "status",
        "revision"
      ],
      "type": "object"
    },
    "FindingSeverity": {
      "enum": [
        "info",
        "warning",
        "blocker"
      ],
      "type": "string"
    },
    "FindingStatus": {
      "enum": [
        "open",
        "accepted-risk",
        "resolved",
        "dismissed"
      ],
      "type": "string"
    },
    "FindingTarget": {
      "oneOf": [
        {
          "additionalProperties": false,
          "properties": {
            "document_set": {
              "$ref": "#/$defs/ArtifactReference"
            },
            "kind": {
              "const": "document-set",
              "type": "string"
            }
          },
          "required": [
            "kind",
            "document_set"
          ],
          "type": "object"
        },
        {
          "additionalProperties": false,
          "properties": {
            "document": {
              "$ref": "#/$defs/ArtifactReference"
            },
            "document_id": {
              "type": "string"
            },
            "kind": {
              "const": "document",
              "type": "string"
            }
          },
          "required": [
            "kind",
            "document",
            "document_id"
          ],
          "type": "object"
        },
        {
          "additionalProperties": false,
          "properties": {
            "document": {
              "$ref": "#/$defs/ArtifactReference"
            },
            "document_id": {
              "type": "string"
            },
            "kind": {
              "const": "section",
              "type": "string"
            },
            "section_id": {
              "type": "string"
            }
          },
          "required": [
            "kind",
            "document",
            "document_id",
            "section_id"
          ],
          "type": "object"
        },
        {
          "additionalProperties": false,
          "properties": {
            "claim_id": {
              "type": "string"
            },
            "document": {
              "$ref": "#/$defs/ArtifactReference"
            },
            "document_id": {
              "type": "string"
            },
            "kind": {
              "const": "claim",
              "type": "string"
            },
            "section_id": {
              "type": "string"
            }
          },
          "required": [
            "kind",
            "document",
            "document_id",
            "section_id",
            "claim_id"
          ],
          "type": "object"
        },
        {
          "additionalProperties": false,
          "properties": {
            "document": {
              "$ref": "#/$defs/ArtifactReference"
            },
            "document_id": {
              "type": "string"
            },
            "kind": {
              "const": "placeholder",
              "type": "string"
            },
            "placeholder_id": {
              "type": "string"
            }
          },
          "required": [
            "kind",
            "document",
            "document_id",
            "placeholder_id"
          ],
          "type": "object"
        }
      ]
    }
  },
  "$id": "https://schemas.canisend.dev/v2/review-findings.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "document_set_artifact": {
      "$ref": "#/$defs/ArtifactReference"
    },
    "findings": {
      "items": {
        "$ref": "#/$defs/FindingRecord"
      },
      "type": "array"
    },
    "id": {
      "type": "string"
    },
    "job_id": {
      "type": "string"
    },
    "reviewed_by": {
      "$ref": "#/$defs/ActorKind"
    },
    "revision": {
      "format": "uint64",
      "minimum": 0,
      "type": "integer"
    }
  },
  "required": [
    "id",
    "job_id",
    "document_set_artifact",
    "findings",
    "reviewed_by",
    "revision"
  ],
  "title": "ReviewFindingsRecord",
  "type": "object",
  "x-canisend-id": "canisend.review-findings/v2",
  "x-canisend-version": "2.0.0"
}
