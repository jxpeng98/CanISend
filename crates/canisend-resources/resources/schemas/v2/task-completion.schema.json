{
  "$defs": {
    "ExpectedInputRevision": {
      "additionalProperties": false,
      "properties": {
        "artifact_id": {
          "type": "string"
        },
        "revision": {
          "format": "uint64",
          "minimum": 0,
          "type": "integer"
        },
        "sha256": {
          "type": "string"
        }
      },
      "required": [
        "artifact_id",
        "revision",
        "sha256"
      ],
      "type": "object"
    }
  },
  "$id": "https://schemas.canisend.dev/v2/task-completion.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "candidate": true,
    "expected_inputs": {
      "items": {
        "$ref": "#/$defs/ExpectedInputRevision"
      },
      "type": "array"
    },
    "expected_job_revision": {
      "format": "uint64",
      "minimum": 0,
      "type": "integer"
    },
    "lease_id": {
      "type": "string"
    },
    "task_id": {
      "type": "string"
    }
  },
  "required": [
    "task_id",
    "lease_id",
    "expected_job_revision",
    "expected_inputs",
    "candidate"
  ],
  "title": "TaskCompletionRequest",
  "type": "object",
  "x-canisend-id": "canisend.task-completion/v2",
  "x-canisend-version": "2.0.0"
}
