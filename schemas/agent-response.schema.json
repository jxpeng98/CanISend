{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/jxpeng98/CanISend/schemas/agent-response.schema.json",
  "title": "CanISendAgentResponse",
  "description": "Stable machine-readable response envelope for CanISend agent operations.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "protocol": {
      "const": "canisend.agent/v1"
    },
    "schema_version": {
      "const": "1.0.0"
    },
    "request_id": {
      "type": "string",
      "pattern": "^req_[0-9a-f]{32}$"
    },
    "operation": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_-]*(\\.[a-z][a-z0-9_-]*)+$"
    },
    "ok": {
      "type": "boolean"
    },
    "job": {
      "oneOf": [
        { "$ref": "#/$defs/jobReference" },
        { "type": "null" }
      ]
    },
    "workflow": {
      "oneOf": [
        { "$ref": "#/$defs/workflowSnapshotReference" },
        { "type": "null" }
      ]
    },
    "artifacts": {
      "type": "array",
      "items": { "$ref": "#/$defs/artifactReference" }
    },
    "missing_fields": {
      "type": "array",
      "items": { "type": "string" }
    },
    "required_consents": {
      "type": "array",
      "items": { "$ref": "#/$defs/consentRequirement" }
    },
    "warnings": {
      "type": "array",
      "items": { "type": "string" }
    },
    "blockers": {
      "type": "array",
      "items": { "type": "string" }
    },
    "next_actions": {
      "type": "array",
      "items": { "$ref": "#/$defs/nextAction" }
    },
    "gate": {
      "oneOf": [
        { "$ref": "#/$defs/gateOutcome" },
        { "type": "null" }
      ]
    },
    "error": {
      "oneOf": [
        { "$ref": "#/$defs/agentError" },
        { "type": "null" }
      ]
    },
    "extensions": {
      "type": "object",
      "propertyNames": {
        "pattern": "^[a-z][a-z0-9_-]*(\\.[a-z][a-z0-9_-]*)+$"
      },
      "additionalProperties": {
        "type": ["string", "integer", "number", "boolean", "null"]
      }
    }
  },
  "required": [
    "protocol",
    "schema_version",
    "request_id",
    "operation",
    "ok",
    "job",
    "workflow",
    "artifacts",
    "missing_fields",
    "required_consents",
    "warnings",
    "blockers",
    "next_actions",
    "gate",
    "error",
    "extensions"
  ],
  "allOf": [
    {
      "if": {
        "properties": { "ok": { "const": true } },
        "required": ["ok"]
      },
      "then": {
        "properties": { "error": { "type": "null" } }
      },
      "else": {
        "properties": { "error": { "$ref": "#/$defs/agentError" } }
      }
    }
  ],
  "$defs": {
    "workspacePath": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(?!/)(?![A-Za-z]:)(?!.*(?:^|/)\\.{1,2}(?:/|$))(?!.*\\\\)[^/]+(?:/[^/]+)*$"
    },
    "slugIdentifier": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9_.-]*$"
    },
    "dottedIdentifier": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_-]*(\\.[a-z][a-z0-9_-]*)+$"
    },
    "privacyTier": {
      "type": "integer",
      "minimum": 0,
      "maximum": 3
    },
    "trustLevel": {
      "enum": [
        "trusted_local",
        "untrusted_import",
        "validated",
        "generated_candidate"
      ]
    },
    "agentError": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "code": { "$ref": "#/$defs/dottedIdentifier" },
        "message": { "type": "string", "minLength": 1 },
        "retryable": { "type": "boolean" },
        "hint": { "type": ["string", "null"] }
      },
      "required": ["code", "message", "retryable", "hint"]
    },
    "artifactReference": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "kind": { "$ref": "#/$defs/slugIdentifier" },
        "path": {
          "oneOf": [
            { "$ref": "#/$defs/workspacePath" },
            { "type": "null" }
          ]
        },
        "opaque_id": {
          "type": ["string", "null"],
          "pattern": "^external-[0-9a-f]{16}$"
        },
        "exists": { "type": "boolean" },
        "sha256": {
          "type": ["string", "null"],
          "pattern": "^[0-9a-f]{64}$"
        },
        "privacy_tier": { "$ref": "#/$defs/privacyTier" },
        "trust_level": { "$ref": "#/$defs/trustLevel" },
        "media_type": { "type": ["string", "null"] }
      },
      "required": [
        "kind",
        "path",
        "opaque_id",
        "exists",
        "sha256",
        "privacy_tier",
        "trust_level",
        "media_type"
      ],
      "oneOf": [
        {
          "properties": {
            "path": { "$ref": "#/$defs/workspacePath" },
            "opaque_id": { "type": "null" }
          }
        },
        {
          "properties": {
            "path": { "type": "null" },
            "opaque_id": { "type": "string", "pattern": "^external-[0-9a-f]{16}$" },
            "sha256": { "type": "null" }
          }
        }
      ]
    },
    "consentRequirement": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "id": { "$ref": "#/$defs/slugIdentifier" },
        "purpose": { "type": "string", "minLength": 1 },
        "privacy_tier": { "$ref": "#/$defs/privacyTier" },
        "artifact_kinds": {
          "type": "array",
          "items": { "$ref": "#/$defs/slugIdentifier" }
        },
        "required": { "type": "boolean" }
      },
      "required": ["id", "purpose", "privacy_tier", "artifact_kinds", "required"]
    },
    "nextAction": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "id": { "$ref": "#/$defs/dottedIdentifier" },
        "label": { "type": "string", "minLength": 1 },
        "requires_consent": { "type": "boolean" },
        "consent_ids": {
          "type": "array",
          "items": { "$ref": "#/$defs/slugIdentifier" }
        }
      },
      "required": ["id", "label", "requires_consent", "consent_ids"],
      "allOf": [
        {
          "if": {
            "properties": { "requires_consent": { "const": true } },
            "required": ["requires_consent"]
          },
          "then": {
            "properties": { "consent_ids": { "minItems": 1 } }
          },
          "else": {
            "properties": { "consent_ids": { "maxItems": 0 } }
          }
        }
      ]
    },
    "jobReference": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "path": { "$ref": "#/$defs/workspacePath" },
        "title": { "type": "string", "minLength": 1 },
        "institution": { "type": "string", "minLength": 1 },
        "deadline": { "type": "string" },
        "status": { "type": "string", "minLength": 1 }
      },
      "required": ["id", "path", "title", "institution", "deadline", "status"]
    },
    "workflowSnapshotReference": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "phase": {
          "enum": ["intake", "evidence", "parse", "package", "verify", "render", "unknown"]
        },
        "readiness": {
          "enum": [
            "blocked",
            "action_required",
            "review_required",
            "ready_for_next_stage",
            "unknown"
          ]
        },
        "derived": { "type": "boolean" }
      },
      "required": ["phase", "readiness", "derived"]
    },
    "gateOutcome": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "status": { "enum": ["PASS", "FAIL", "STALE", "NOT_RUN"] },
        "issue_count": { "type": "integer", "minimum": 0 },
        "report_path": {
          "oneOf": [
            { "$ref": "#/$defs/workspacePath" },
            { "type": "null" }
          ]
        }
      },
      "required": ["status", "issue_count", "report_path"]
    }
  }
}
