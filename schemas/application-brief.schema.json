{
  "$defs": {
    "ConfirmedIdSelectionV1": {
      "additionalProperties": false,
      "properties": {
        "criterion_ids": {
          "default": [],
          "items": {
            "pattern": "^criterion_[0-9a-f]{32}$",
            "type": "string"
          },
          "maxItems": 4096,
          "title": "Criterion Ids",
          "type": "array",
          "uniqueItems": true
        },
        "evidence_ref_ids": {
          "default": [],
          "items": {
            "pattern": "^evidence_[0-9a-f]{32}$",
            "type": "string"
          },
          "maxItems": 4096,
          "title": "Evidence Ref Ids",
          "type": "array",
          "uniqueItems": true
        },
        "confirmation_state": {
          "default": "unconfirmed",
          "enum": [
            "unconfirmed",
            "confirmed"
          ],
          "title": "Confirmation State",
          "type": "string"
        }
      },
      "title": "ConfirmedIdSelectionV1",
      "type": "object"
    },
    "ConfirmedStringListV1": {
      "additionalProperties": false,
      "properties": {
        "items": {
          "default": [],
          "items": {
            "maxLength": 10000,
            "minLength": 1,
            "pattern": "[\\s\\S]*\\S[\\s\\S]*",
            "type": "string"
          },
          "maxItems": 4096,
          "title": "Items",
          "type": "array",
          "uniqueItems": true
        },
        "confirmation_state": {
          "default": "unconfirmed",
          "enum": [
            "unconfirmed",
            "confirmed"
          ],
          "title": "Confirmation State",
          "type": "string"
        }
      },
      "title": "ConfirmedStringListV1",
      "type": "object"
    },
    "ConfirmedTextV1": {
      "additionalProperties": false,
      "allOf": [
        {
          "if": {
            "properties": {
              "confirmation_state": {
                "const": "confirmed"
              }
            },
            "required": [
              "confirmation_state"
            ]
          },
          "then": {
            "properties": {
              "value": {
                "not": {
                  "type": "null"
                }
              }
            },
            "required": [
              "value"
            ]
          }
        }
      ],
      "properties": {
        "value": {
          "anyOf": [
            {
              "maxLength": 200000,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Value"
        },
        "confirmation_state": {
          "default": "unconfirmed",
          "enum": [
            "unconfirmed",
            "confirmed"
          ],
          "title": "Confirmation State",
          "type": "string"
        }
      },
      "title": "ConfirmedTextV1",
      "type": "object"
    },
    "DocumentChoiceV1": {
      "additionalProperties": false,
      "allOf": [
        {
          "if": {
            "properties": {
              "action": {
                "enum": [
                  "prepare",
                  "omit"
                ]
              }
            },
            "required": [
              "action"
            ]
          },
          "then": {
            "properties": {
              "confirmation_state": {
                "const": "confirmed"
              }
            },
            "required": [
              "confirmation_state"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "confirmation_state": {
                "const": "confirmed"
              }
            },
            "required": [
              "confirmation_state"
            ]
          },
          "then": {
            "properties": {
              "action": {
                "enum": [
                  "prepare",
                  "omit"
                ]
              }
            },
            "required": [
              "action"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "action": {
                "const": "needs_confirmation"
              }
            },
            "required": [
              "action"
            ]
          },
          "then": {
            "properties": {
              "confirmation_state": {
                "const": "unconfirmed"
              }
            }
          }
        }
      ],
      "properties": {
        "document_id": {
          "pattern": "^document_[0-9a-f]{32}$",
          "title": "Document Id",
          "type": "string"
        },
        "action": {
          "default": "needs_confirmation",
          "enum": [
            "prepare",
            "omit",
            "needs_confirmation"
          ],
          "title": "Action",
          "type": "string"
        },
        "confirmation_state": {
          "default": "unconfirmed",
          "enum": [
            "unconfirmed",
            "confirmed"
          ],
          "title": "Confirmation State",
          "type": "string"
        }
      },
      "required": [
        "document_id"
      ],
      "title": "DocumentChoiceV1",
      "type": "object"
    },
    "DocumentRequirementsConfirmationV1": {
      "additionalProperties": false,
      "allOf": [
        {
          "else": {
            "properties": {
              "basis_sha256": {
                "not": {
                  "type": "null"
                }
              },
              "confirmed_at": {
                "not": {
                  "type": "null"
                }
              }
            },
            "required": [
              "basis_sha256",
              "confirmed_at"
            ]
          },
          "if": {
            "properties": {
              "state": {
                "const": "unconfirmed"
              }
            }
          },
          "then": {
            "properties": {
              "basis_sha256": {
                "type": "null"
              },
              "confirmed_at": {
                "type": "null"
              }
            }
          }
        }
      ],
      "properties": {
        "state": {
          "default": "unconfirmed",
          "enum": [
            "unconfirmed",
            "confirmed",
            "confirmed_empty"
          ],
          "title": "State",
          "type": "string"
        },
        "basis_sha256": {
          "anyOf": [
            {
              "pattern": "^[0-9a-f]{64}$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Basis Sha256"
        },
        "confirmed_at": {
          "anyOf": [
            {
              "format": "date-time",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "pattern": "^\\d{4}-\\d{2}-\\d{2}[Tt]\\d{2}:\\d{2}:\\d{2}(?:\\.\\d+)?(?:[Zz]|[+-]\\d{2}:\\d{2})$",
          "title": "Confirmed At"
        }
      },
      "title": "DocumentRequirementsConfirmationV1",
      "type": "object"
    },
    "LanguagePreferenceV1": {
      "additionalProperties": false,
      "allOf": [
        {
          "if": {
            "properties": {
              "confirmation_state": {
                "const": "confirmed"
              }
            },
            "required": [
              "confirmation_state"
            ]
          },
          "then": {
            "properties": {
              "value": {
                "not": {
                  "type": "null"
                }
              }
            },
            "required": [
              "value"
            ]
          }
        }
      ],
      "properties": {
        "value": {
          "anyOf": [
            {
              "enum": [
                "uk",
                "us"
              ],
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Value"
        },
        "confirmation_state": {
          "default": "unconfirmed",
          "enum": [
            "unconfirmed",
            "confirmed"
          ],
          "title": "Confirmation State",
          "type": "string"
        }
      },
      "title": "LanguagePreferenceV1",
      "type": "object"
    }
  },
  "$id": "https://github.com/jxpeng98/CanISend/schemas/application-brief.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "const": "1.0.0",
      "default": "1.0.0",
      "title": "Schema Version",
      "type": "string"
    },
    "job_id": {
      "pattern": "^[a-z0-9][a-z0-9_.-]*$",
      "title": "Job Id",
      "type": "string"
    },
    "revision": {
      "maximum": 9223372036854775807,
      "minimum": 0,
      "title": "Revision",
      "type": "integer"
    },
    "updated_at": {
      "format": "date-time",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}[Tt]\\d{2}:\\d{2}:\\d{2}(?:\\.\\d+)?(?:[Zz]|[+-]\\d{2}:\\d{2})$",
      "title": "Updated At",
      "type": "string"
    },
    "decision_sha256": {
      "anyOf": [
        {
          "pattern": "^[0-9a-f]{64}$",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Decision Sha256"
    },
    "language": {
      "$ref": "#/$defs/LanguagePreferenceV1"
    },
    "writing_style": {
      "$ref": "#/$defs/ConfirmedTextV1"
    },
    "motivation": {
      "$ref": "#/$defs/ConfirmedTextV1"
    },
    "emphasis": {
      "$ref": "#/$defs/ConfirmedIdSelectionV1"
    },
    "exclusions": {
      "$ref": "#/$defs/ConfirmedStringListV1"
    },
    "document_requirements_confirmation": {
      "$ref": "#/$defs/DocumentRequirementsConfirmationV1"
    },
    "document_choices": {
      "default": [],
      "items": {
        "$ref": "#/$defs/DocumentChoiceV1"
      },
      "maxItems": 4096,
      "title": "Document Choices",
      "type": "array",
      "uniqueItems": true
    }
  },
  "required": [
    "job_id",
    "revision",
    "updated_at"
  ],
  "title": "CanISendApplicationBriefV1",
  "type": "object"
}
