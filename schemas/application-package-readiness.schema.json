{
  "$defs": {
    "PackageDocumentReviewV1": {
      "additionalProperties": false,
      "allOf": [
        {
          "if": {
            "properties": {
              "action": {
                "const": "omit"
              }
            },
            "required": [
              "action"
            ]
          },
          "then": {
            "properties": {
              "state": {
                "const": "omitted"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "state": {
                "const": "omitted"
              }
            },
            "required": [
              "state"
            ]
          },
          "then": {
            "properties": {
              "action": {
                "const": "omit"
              },
              "draft_sha256": {
                "type": "null"
              },
              "review_findings_sha256": {
                "type": "null"
              },
              "review_dispositions_sha256": {
                "type": "null"
              },
              "document_readiness_sha256": {
                "type": "null"
              },
              "readiness_state": {
                "type": "null"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "state": {
                "const": "plan_blocked"
              }
            },
            "required": [
              "state"
            ]
          },
          "then": {
            "properties": {
              "action": {
                "const": "prepare"
              },
              "draft_sha256": {
                "type": "null"
              },
              "review_findings_sha256": {
                "type": "null"
              },
              "review_dispositions_sha256": {
                "type": "null"
              },
              "document_readiness_sha256": {
                "type": "null"
              },
              "readiness_state": {
                "type": "null"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "state": {
                "const": "executor_unavailable"
              }
            },
            "required": [
              "state"
            ]
          },
          "then": {
            "properties": {
              "action": {
                "const": "prepare"
              },
              "executor_availability": {
                "enum": [
                  "planned",
                  "unregistered"
                ]
              },
              "draft_sha256": {
                "type": "null"
              },
              "review_findings_sha256": {
                "type": "null"
              },
              "review_dispositions_sha256": {
                "type": "null"
              },
              "document_readiness_sha256": {
                "type": "null"
              },
              "readiness_state": {
                "type": "null"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "state": {
                "const": "draft_missing"
              }
            },
            "required": [
              "state"
            ]
          },
          "then": {
            "properties": {
              "action": {
                "const": "prepare"
              },
              "executor_availability": {
                "const": "available"
              },
              "draft_sha256": {
                "type": "null"
              },
              "review_findings_sha256": {
                "type": "null"
              },
              "review_dispositions_sha256": {
                "type": "null"
              },
              "document_readiness_sha256": {
                "type": "null"
              },
              "readiness_state": {
                "type": "null"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "state": {
                "enum": [
                  "draft_not_current",
                  "review_missing"
                ]
              }
            },
            "required": [
              "state"
            ]
          },
          "then": {
            "properties": {
              "action": {
                "const": "prepare"
              },
              "executor_availability": {
                "const": "available"
              },
              "draft_sha256": {
                "not": {
                  "type": "null"
                }
              },
              "review_findings_sha256": {
                "type": "null"
              },
              "review_dispositions_sha256": {
                "type": "null"
              },
              "document_readiness_sha256": {
                "type": "null"
              },
              "readiness_state": {
                "type": "null"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "state": {
                "const": "review_not_current"
              }
            },
            "required": [
              "state"
            ]
          },
          "then": {
            "properties": {
              "action": {
                "const": "prepare"
              },
              "executor_availability": {
                "const": "available"
              },
              "draft_sha256": {
                "not": {
                  "type": "null"
                }
              },
              "review_findings_sha256": {
                "not": {
                  "type": "null"
                }
              },
              "review_dispositions_sha256": {
                "type": "null"
              },
              "document_readiness_sha256": {
                "type": "null"
              },
              "readiness_state": {
                "type": "null"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "state": {
                "const": "blocked"
              }
            },
            "required": [
              "state"
            ]
          },
          "then": {
            "properties": {
              "action": {
                "const": "prepare"
              },
              "executor_availability": {
                "const": "available"
              },
              "draft_sha256": {
                "not": {
                  "type": "null"
                }
              },
              "review_findings_sha256": {
                "not": {
                  "type": "null"
                }
              },
              "document_readiness_sha256": {
                "not": {
                  "type": "null"
                }
              },
              "readiness_state": {
                "const": "blocked"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "state": {
                "const": "review_required"
              }
            },
            "required": [
              "state"
            ]
          },
          "then": {
            "properties": {
              "action": {
                "const": "prepare"
              },
              "executor_availability": {
                "const": "available"
              },
              "draft_sha256": {
                "not": {
                  "type": "null"
                }
              },
              "review_findings_sha256": {
                "not": {
                  "type": "null"
                }
              },
              "document_readiness_sha256": {
                "not": {
                  "type": "null"
                }
              },
              "readiness_state": {
                "const": "review_required"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "state": {
                "const": "revision_required"
              }
            },
            "required": [
              "state"
            ]
          },
          "then": {
            "properties": {
              "action": {
                "const": "prepare"
              },
              "executor_availability": {
                "const": "available"
              },
              "draft_sha256": {
                "not": {
                  "type": "null"
                }
              },
              "review_findings_sha256": {
                "not": {
                  "type": "null"
                }
              },
              "document_readiness_sha256": {
                "not": {
                  "type": "null"
                }
              },
              "readiness_state": {
                "const": "revision_required"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "state": {
                "const": "reviewed"
              }
            },
            "required": [
              "state"
            ]
          },
          "then": {
            "properties": {
              "action": {
                "const": "prepare"
              },
              "executor_availability": {
                "const": "available"
              },
              "draft_sha256": {
                "not": {
                  "type": "null"
                }
              },
              "review_findings_sha256": {
                "not": {
                  "type": "null"
                }
              },
              "document_readiness_sha256": {
                "not": {
                  "type": "null"
                }
              },
              "readiness_state": {
                "const": "reviewed"
              }
            }
          }
        },
        {
          "else": {
            "properties": {
              "reason_codes": {
                "minItems": 1
              }
            }
          },
          "if": {
            "properties": {
              "state": {
                "const": "reviewed"
              }
            },
            "required": [
              "state"
            ]
          },
          "then": {
            "properties": {
              "review_dispositions_sha256": {
                "not": {
                  "type": "null"
                }
              },
              "reason_codes": {
                "maxItems": 0
              }
            }
          }
        }
      ],
      "properties": {
        "document_id": {
          "pattern": "^document_[0-9a-f]{32}$",
          "title": "Document Id",
          "type": "string"
        },
        "normalized_kind": {
          "pattern": "^[a-z][a-z0-9_]*$",
          "title": "Normalized Kind",
          "type": "string"
        },
        "requirement": {
          "enum": [
            "required",
            "optional",
            "unknown"
          ],
          "title": "Requirement",
          "type": "string"
        },
        "action": {
          "enum": [
            "prepare",
            "omit",
            "needs_confirmation"
          ],
          "title": "Action",
          "type": "string"
        },
        "executor_availability": {
          "enum": [
            "available",
            "planned",
            "unregistered"
          ],
          "title": "Executor Availability",
          "type": "string"
        },
        "state": {
          "enum": [
            "omitted",
            "plan_blocked",
            "executor_unavailable",
            "draft_missing",
            "draft_not_current",
            "review_missing",
            "review_not_current",
            "blocked",
            "review_required",
            "revision_required",
            "reviewed"
          ],
          "title": "State",
          "type": "string"
        },
        "draft_sha256": {
          "anyOf": [
            {
              "pattern": "^[0-9a-f]{64}$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Draft Sha256"
        },
        "review_findings_sha256": {
          "anyOf": [
            {
              "pattern": "^[0-9a-f]{64}$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Review Findings Sha256"
        },
        "review_dispositions_sha256": {
          "anyOf": [
            {
              "pattern": "^[0-9a-f]{64}$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Review Dispositions Sha256"
        },
        "document_readiness_sha256": {
          "anyOf": [
            {
              "pattern": "^[0-9a-f]{64}$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Document Readiness Sha256"
        },
        "readiness_state": {
          "anyOf": [
            {
              "enum": [
                "blocked",
                "review_required",
                "revision_required",
                "reviewed"
              ],
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Readiness State"
        },
        "claim_ids": {
          "default": [],
          "items": {
            "pattern": "^claim_[0-9a-f]{32}$",
            "type": "string"
          },
          "maxItems": 4096,
          "title": "Claim Ids",
          "type": "array",
          "uniqueItems": true
        },
        "reason_codes": {
          "default": [],
          "items": {
            "pattern": "^[a-z][a-z0-9_-]*(?:\\.[a-z][a-z0-9_-]*)+$",
            "type": "string"
          },
          "maxItems": 64,
          "title": "Reason Codes",
          "type": "array",
          "uniqueItems": true
        }
      },
      "required": [
        "document_id",
        "normalized_kind",
        "requirement",
        "action",
        "executor_availability",
        "state"
      ],
      "title": "PackageDocumentReviewV1",
      "type": "object"
    }
  },
  "$id": "https://github.com/jxpeng98/CanISend/schemas/application-package-readiness.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "allOf": [
    {
      "if": {
        "properties": {
          "state": {
            "const": "blocked"
          }
        },
        "required": [
          "state"
        ]
      },
      "then": {
        "anyOf": [
          {
            "properties": {
              "blocker_finding_ids": {
                "minItems": 1
              }
            }
          },
          {
            "properties": {
              "reason_codes": {
                "contains": {
                  "const": "package.required_document_not_reviewed"
                }
              }
            }
          }
        ]
      }
    },
    {
      "if": {
        "properties": {
          "state": {
            "const": "revision_required"
          }
        },
        "required": [
          "state"
        ]
      },
      "then": {
        "properties": {
          "blocker_finding_ids": {
            "maxItems": 0
          },
          "revision_required_finding_ids": {
            "minItems": 1
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "state": {
            "const": "reviewed"
          }
        },
        "required": [
          "state"
        ]
      },
      "then": {
        "properties": {
          "package_review_dispositions_sha256": {
            "not": {
              "type": "null"
            }
          },
          "revision_required_finding_ids": {
            "maxItems": 0
          },
          "unresolved_finding_ids": {
            "maxItems": 0
          },
          "blocker_finding_ids": {
            "maxItems": 0
          },
          "reason_codes": {
            "maxItems": 0
          }
        }
      }
    }
  ],
  "properties": {
    "schema_version": {
      "const": "1.0.0",
      "default": "1.0.0",
      "title": "Schema Version",
      "type": "string"
    },
    "job_id": {
      "pattern": "^[a-z0-9][a-z0-9_.-]*$",
      "title": "Job Id",
      "type": "string"
    },
    "state": {
      "enum": [
        "blocked",
        "review_required",
        "revision_required",
        "reviewed"
      ],
      "title": "State",
      "type": "string"
    },
    "required_document_plan_sha256": {
      "pattern": "^[0-9a-f]{64}$",
      "title": "Required Document Plan Sha256",
      "type": "string"
    },
    "document_execution_plan_sha256": {
      "pattern": "^[0-9a-f]{64}$",
      "title": "Document Execution Plan Sha256",
      "type": "string"
    },
    "package_review_findings_sha256": {
      "pattern": "^[0-9a-f]{64}$",
      "title": "Package Review Findings Sha256",
      "type": "string"
    },
    "package_review_dispositions_sha256": {
      "anyOf": [
        {
          "pattern": "^[0-9a-f]{64}$",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Package Review Dispositions Sha256"
    },
    "required_documents": {
      "default": [],
      "items": {
        "$ref": "#/$defs/PackageDocumentReviewV1"
      },
      "maxItems": 4096,
      "title": "Required Documents",
      "type": "array",
      "uniqueItems": true
    },
    "required_document_ids": {
      "default": [],
      "items": {
        "pattern": "^document_[0-9a-f]{32}$",
        "type": "string"
      },
      "maxItems": 4096,
      "title": "Required Document Ids",
      "type": "array",
      "uniqueItems": true
    },
    "reviewed_required_document_ids": {
      "default": [],
      "items": {
        "pattern": "^document_[0-9a-f]{32}$",
        "type": "string"
      },
      "maxItems": 4096,
      "title": "Reviewed Required Document Ids",
      "type": "array",
      "uniqueItems": true
    },
    "optional_document_ids": {
      "default": [],
      "items": {
        "pattern": "^document_[0-9a-f]{32}$",
        "type": "string"
      },
      "maxItems": 4096,
      "title": "Optional Document Ids",
      "type": "array",
      "uniqueItems": true
    },
    "accepted_finding_ids": {
      "default": [],
      "items": {
        "pattern": "^finding_[0-9a-f]{32}$",
        "type": "string"
      },
      "maxItems": 4096,
      "title": "Accepted Finding Ids",
      "type": "array",
      "uniqueItems": true
    },
    "revision_required_finding_ids": {
      "default": [],
      "items": {
        "pattern": "^finding_[0-9a-f]{32}$",
        "type": "string"
      },
      "maxItems": 4096,
      "title": "Revision Required Finding Ids",
      "type": "array",
      "uniqueItems": true
    },
    "unresolved_finding_ids": {
      "default": [],
      "items": {
        "pattern": "^finding_[0-9a-f]{32}$",
        "type": "string"
      },
      "maxItems": 4096,
      "title": "Unresolved Finding Ids",
      "type": "array",
      "uniqueItems": true
    },
    "blocker_finding_ids": {
      "default": [],
      "items": {
        "pattern": "^finding_[0-9a-f]{32}$",
        "type": "string"
      },
      "maxItems": 4096,
      "title": "Blocker Finding Ids",
      "type": "array",
      "uniqueItems": true
    },
    "reason_codes": {
      "default": [],
      "items": {
        "pattern": "^[a-z][a-z0-9_-]*(?:\\.[a-z][a-z0-9_-]*)+$",
        "type": "string"
      },
      "maxItems": 64,
      "title": "Reason Codes",
      "type": "array",
      "uniqueItems": true
    }
  },
  "required": [
    "job_id",
    "state",
    "required_document_plan_sha256",
    "document_execution_plan_sha256",
    "package_review_findings_sha256"
  ],
  "title": "CanISendApplicationPackageReadinessV1",
  "type": "object"
}
