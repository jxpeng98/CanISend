{
  "$defs": {
    "CriteriaExtractionConfirmationV1": {
      "additionalProperties": false,
      "allOf": [
        {
          "else": {
            "properties": {
              "superseded_by": {
                "type": "null"
              }
            }
          },
          "if": {
            "properties": {
              "record_state": {
                "const": "superseded"
              }
            },
            "required": [
              "record_state"
            ]
          },
          "then": {
            "properties": {
              "superseded_by": {
                "not": {
                  "type": "null"
                }
              }
            },
            "required": [
              "superseded_by"
            ]
          }
        }
      ],
      "properties": {
        "correction_id": {
          "pattern": "^correction_[0-9a-f]{32}$",
          "title": "Correction Id",
          "type": "string"
        },
        "target_extraction_sha256": {
          "pattern": "^[0-9a-f]{64}$",
          "title": "Target Extraction Sha256",
          "type": "string"
        },
        "confirmation": {
          "const": "confirmed_empty",
          "title": "Confirmation",
          "type": "string"
        },
        "record_state": {
          "default": "active",
          "enum": [
            "active",
            "superseded",
            "withdrawn"
          ],
          "title": "Record State",
          "type": "string"
        },
        "superseded_by": {
          "anyOf": [
            {
              "pattern": "^correction_[0-9a-f]{32}$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Superseded By"
        },
        "confirmed_at": {
          "format": "date-time",
          "title": "Confirmed At",
          "type": "string"
        }
      },
      "required": [
        "correction_id",
        "target_extraction_sha256",
        "confirmation",
        "confirmed_at"
      ],
      "title": "CriteriaExtractionConfirmationV1",
      "type": "object"
    },
    "CriterionCorrectionV1": {
      "additionalProperties": false,
      "allOf": [
        {
          "else": {
            "properties": {
              "corrected_text": {
                "type": "null"
              }
            }
          },
          "if": {
            "properties": {
              "confirmation": {
                "const": "corrected"
              }
            }
          },
          "then": {
            "properties": {
              "corrected_text": {
                "minLength": 1,
                "type": "string"
              }
            },
            "required": [
              "corrected_text"
            ]
          }
        },
        {
          "else": {
            "properties": {
              "source_anchor_sha256": {
                "type": "null"
              }
            }
          },
          "if": {
            "properties": {
              "source_occurrence": {
                "type": "integer"
              }
            },
            "required": [
              "source_occurrence"
            ]
          },
          "then": {
            "properties": {
              "source_anchor_sha256": {
                "not": {
                  "type": "null"
                }
              }
            },
            "required": [
              "source_anchor_sha256"
            ]
          }
        },
        {
          "else": {
            "properties": {
              "superseded_by": {
                "type": "null"
              }
            }
          },
          "if": {
            "properties": {
              "record_state": {
                "const": "superseded"
              }
            },
            "required": [
              "record_state"
            ]
          },
          "then": {
            "properties": {
              "superseded_by": {
                "not": {
                  "type": "null"
                }
              }
            },
            "required": [
              "superseded_by"
            ]
          }
        }
      ],
      "properties": {
        "correction_id": {
          "pattern": "^correction_[0-9a-f]{32}$",
          "title": "Correction Id",
          "type": "string"
        },
        "criterion_id": {
          "pattern": "^criterion_[0-9a-f]{32}$",
          "title": "Criterion Id",
          "type": "string"
        },
        "target_source_sha256": {
          "pattern": "^[0-9a-f]{64}$",
          "title": "Target Source Sha256",
          "type": "string"
        },
        "target_criterion_sha256": {
          "pattern": "^[0-9a-f]{64}$",
          "title": "Target Criterion Sha256",
          "type": "string"
        },
        "confirmation": {
          "enum": [
            "confirmed",
            "corrected"
          ],
          "title": "Confirmation",
          "type": "string"
        },
        "corrected_text": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Corrected Text"
        },
        "source_occurrence": {
          "anyOf": [
            {
              "minimum": 1,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Source Occurrence"
        },
        "source_anchor_sha256": {
          "anyOf": [
            {
              "pattern": "^[0-9a-f]{64}$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Source Anchor Sha256"
        },
        "record_state": {
          "default": "active",
          "enum": [
            "active",
            "superseded",
            "withdrawn"
          ],
          "title": "Record State",
          "type": "string"
        },
        "superseded_by": {
          "anyOf": [
            {
              "pattern": "^correction_[0-9a-f]{32}$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Superseded By"
        },
        "confirmed_at": {
          "format": "date-time",
          "title": "Confirmed At",
          "type": "string"
        }
      },
      "required": [
        "correction_id",
        "criterion_id",
        "target_source_sha256",
        "target_criterion_sha256",
        "confirmation",
        "confirmed_at"
      ],
      "title": "CriterionCorrectionV1",
      "type": "object"
    }
  },
  "$id": "https://github.com/jxpeng98/CanISend/schemas/confirmed-corrections.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "const": "1.0.0",
      "default": "1.0.0",
      "title": "Schema Version",
      "type": "string"
    },
    "job_id": {
      "pattern": "^[a-z0-9][a-z0-9_.-]*$",
      "title": "Job Id",
      "type": "string"
    },
    "revision": {
      "maximum": 9223372036854775807,
      "minimum": 0,
      "title": "Revision",
      "type": "integer"
    },
    "updated_at": {
      "format": "date-time",
      "title": "Updated At",
      "type": "string"
    },
    "criteria": {
      "default": [],
      "items": {
        "$ref": "#/$defs/CriterionCorrectionV1"
      },
      "title": "Criteria",
      "type": "array"
    },
    "criteria_extraction_confirmations": {
      "default": [],
      "items": {
        "$ref": "#/$defs/CriteriaExtractionConfirmationV1"
      },
      "title": "Criteria Extraction Confirmations",
      "type": "array"
    }
  },
  "required": [
    "job_id",
    "revision",
    "updated_at"
  ],
  "title": "CanISendConfirmedCorrectionsV1",
  "type": "object"
}
