{
  "$defs": {
    "CorrectionReconciliationV1": {
      "additionalProperties": false,
      "properties": {
        "correction_id": {
          "pattern": "^correction_[0-9a-f]{32}$",
          "title": "Correction Id",
          "type": "string"
        },
        "criterion_id": {
          "pattern": "^criterion_[0-9a-f]{32}$",
          "title": "Criterion Id",
          "type": "string"
        },
        "reason": {
          "pattern": "^[a-z][a-z0-9_-]*(?:\\.[a-z][a-z0-9_-]*)*$",
          "title": "Reason",
          "type": "string"
        }
      },
      "required": [
        "correction_id",
        "criterion_id",
        "reason"
      ],
      "title": "CorrectionReconciliationV1",
      "type": "object"
    },
    "CriterionV1": {
      "additionalProperties": false,
      "allOf": [
        {
          "else": {
            "properties": {
              "source_span": {
                "type": "null"
              },
              "confidence": {
                "const": "unknown"
              },
              "unknown_reason": {
                "minLength": 1,
                "type": "string"
              }
            },
            "required": [
              "unknown_reason"
            ]
          },
          "if": {
            "properties": {
              "source_state": {
                "const": "known"
              }
            }
          },
          "then": {
            "properties": {
              "source_span": {
                "not": {
                  "type": "null"
                }
              },
              "source_candidates": {
                "maxItems": 0
              },
              "confidence": {
                "enum": [
                  "high",
                  "medium",
                  "low"
                ]
              },
              "unknown_reason": {
                "type": "null"
              }
            },
            "required": [
              "source_span"
            ]
          }
        },
        {
          "else": {
            "properties": {
              "source_candidates": {
                "maxItems": 0
              }
            }
          },
          "if": {
            "properties": {
              "unknown_reason": {
                "const": "source_receipt.ambiguous"
              }
            },
            "required": [
              "unknown_reason"
            ]
          },
          "then": {
            "properties": {
              "source_candidates": {
                "minItems": 2
              }
            }
          }
        },
        {
          "else": {
            "properties": {
              "confirmation_record_id": {
                "not": {
                  "type": "null"
                }
              }
            },
            "required": [
              "confirmation_record_id"
            ]
          },
          "if": {
            "properties": {
              "confirmation_state": {
                "const": "unconfirmed"
              }
            }
          },
          "then": {
            "properties": {
              "confirmation_record_id": {
                "type": "null"
              }
            }
          }
        }
      ],
      "properties": {
        "criterion_id": {
          "pattern": "^criterion_[0-9a-f]{32}$",
          "title": "Criterion Id",
          "type": "string"
        },
        "importance": {
          "enum": [
            "essential",
            "desirable"
          ],
          "title": "Importance",
          "type": "string"
        },
        "text": {
          "minLength": 1,
          "title": "Text",
          "type": "string"
        },
        "parsed_text_sha256": {
          "pattern": "^[0-9a-f]{64}$",
          "title": "Parsed Text Sha256",
          "type": "string"
        },
        "source_text": {
          "minLength": 1,
          "title": "Source Text",
          "type": "string"
        },
        "source_state": {
          "enum": [
            "known",
            "unknown"
          ],
          "title": "Source State",
          "type": "string"
        },
        "source_span": {
          "anyOf": [
            {
              "$ref": "#/$defs/SourceSpanV1"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "source_candidates": {
          "default": [],
          "items": {
            "$ref": "#/$defs/SourceSpanV1"
          },
          "title": "Source Candidates",
          "type": "array"
        },
        "confidence": {
          "enum": [
            "high",
            "medium",
            "low",
            "unknown"
          ],
          "title": "Confidence",
          "type": "string"
        },
        "confirmation_state": {
          "default": "unconfirmed",
          "enum": [
            "unconfirmed",
            "confirmed",
            "corrected"
          ],
          "title": "Confirmation State",
          "type": "string"
        },
        "confirmation_record_id": {
          "anyOf": [
            {
              "pattern": "^correction_[0-9a-f]{32}$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Confirmation Record Id"
        },
        "unknown_reason": {
          "anyOf": [
            {
              "pattern": "^[a-z][a-z0-9_-]*(?:\\.[a-z][a-z0-9_-]*)*$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Unknown Reason"
        }
      },
      "required": [
        "criterion_id",
        "importance",
        "text",
        "parsed_text_sha256",
        "source_text",
        "source_state",
        "confidence"
      ],
      "title": "CriterionV1",
      "type": "object"
    },
    "ExtractionConfirmationReconciliationV1": {
      "additionalProperties": false,
      "properties": {
        "correction_id": {
          "pattern": "^correction_[0-9a-f]{32}$",
          "title": "Correction Id",
          "type": "string"
        },
        "reason": {
          "pattern": "^[a-z][a-z0-9_-]*(?:\\.[a-z][a-z0-9_-]*)*$",
          "title": "Reason",
          "type": "string"
        }
      },
      "required": [
        "correction_id",
        "reason"
      ],
      "title": "ExtractionConfirmationReconciliationV1",
      "type": "object"
    },
    "SemanticInputReceiptV1": {
      "additionalProperties": false,
      "properties": {
        "path": {
          "title": "Path",
          "type": "string"
        },
        "projection_sha256": {
          "pattern": "^[0-9a-f]{64}$",
          "title": "Projection Sha256",
          "type": "string"
        }
      },
      "required": [
        "path",
        "projection_sha256"
      ],
      "title": "SemanticInputReceiptV1",
      "type": "object"
    },
    "SourceSpanV1": {
      "additionalProperties": false,
      "properties": {
        "path": {
          "title": "Path",
          "type": "string"
        },
        "start_line": {
          "minimum": 1,
          "title": "Start Line",
          "type": "integer"
        },
        "end_line": {
          "minimum": 1,
          "title": "End Line",
          "type": "integer"
        },
        "text_sha256": {
          "title": "Text Sha256",
          "type": "string"
        },
        "anchor_sha256": {
          "title": "Anchor Sha256",
          "type": "string"
        },
        "occurrence": {
          "minimum": 1,
          "title": "Occurrence",
          "type": "integer"
        },
        "occurrence_count": {
          "minimum": 1,
          "title": "Occurrence Count",
          "type": "integer"
        }
      },
      "required": [
        "path",
        "start_line",
        "end_line",
        "text_sha256",
        "anchor_sha256",
        "occurrence",
        "occurrence_count"
      ],
      "title": "SourceSpanV1",
      "type": "object"
    }
  },
  "$id": "https://github.com/jxpeng98/CanISend/schemas/criteria.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "allOf": [
    {
      "if": {
        "properties": {
          "extraction_state": {
            "const": "extracted"
          }
        }
      },
      "then": {
        "properties": {
          "criteria": {
            "minItems": 1
          },
          "extraction_unknown_reason": {
            "type": "null"
          },
          "empty_confirmation_record_id": {
            "type": "null"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "extraction_state": {
            "const": "unknown"
          }
        }
      },
      "then": {
        "properties": {
          "criteria": {
            "maxItems": 0
          },
          "extraction_unknown_reason": {
            "minLength": 1,
            "type": "string"
          },
          "empty_confirmation_record_id": {
            "type": "null"
          }
        },
        "required": [
          "extraction_unknown_reason"
        ]
      }
    },
    {
      "if": {
        "properties": {
          "extraction_state": {
            "const": "confirmed_empty"
          }
        }
      },
      "then": {
        "properties": {
          "criteria": {
            "maxItems": 0
          },
          "extraction_unknown_reason": {
            "type": "null"
          },
          "empty_confirmation_record_id": {
            "not": {
              "type": "null"
            }
          }
        },
        "required": [
          "empty_confirmation_record_id"
        ]
      }
    }
  ],
  "properties": {
    "schema_version": {
      "const": "1.0.0",
      "default": "1.0.0",
      "title": "Schema Version",
      "type": "string"
    },
    "job_id": {
      "pattern": "^[a-z0-9][a-z0-9_.-]*$",
      "title": "Job Id",
      "type": "string"
    },
    "input_fingerprint": {
      "pattern": "^[0-9a-f]{64}$",
      "title": "Input Fingerprint",
      "type": "string"
    },
    "semantic_inputs": {
      "items": {
        "$ref": "#/$defs/SemanticInputReceiptV1"
      },
      "title": "Semantic Inputs",
      "type": "array"
    },
    "extraction_state": {
      "enum": [
        "extracted",
        "unknown",
        "confirmed_empty"
      ],
      "title": "Extraction State",
      "type": "string"
    },
    "extraction_unknown_reason": {
      "anyOf": [
        {
          "pattern": "^[a-z][a-z0-9_-]*(?:\\.[a-z][a-z0-9_-]*)*$",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Extraction Unknown Reason"
    },
    "empty_confirmation_record_id": {
      "anyOf": [
        {
          "pattern": "^correction_[0-9a-f]{32}$",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Empty Confirmation Record Id"
    },
    "criteria": {
      "items": {
        "$ref": "#/$defs/CriterionV1"
      },
      "title": "Criteria",
      "type": "array"
    },
    "unresolved_criterion_ids": {
      "default": [],
      "items": {
        "pattern": "^criterion_[0-9a-f]{32}$",
        "type": "string"
      },
      "title": "Unresolved Criterion Ids",
      "type": "array"
    },
    "orphaned_corrections": {
      "default": [],
      "items": {
        "$ref": "#/$defs/CorrectionReconciliationV1"
      },
      "title": "Orphaned Corrections",
      "type": "array"
    },
    "orphaned_extraction_confirmations": {
      "default": [],
      "items": {
        "$ref": "#/$defs/ExtractionConfirmationReconciliationV1"
      },
      "title": "Orphaned Extraction Confirmations",
      "type": "array"
    }
  },
  "required": [
    "job_id",
    "input_fingerprint",
    "semantic_inputs",
    "extraction_state",
    "criteria"
  ],
  "title": "CanISendCriteriaCatalogV1",
  "type": "object"
}
