{
  "$defs": {
    "CriterionMatchV1": {
      "additionalProperties": false,
      "properties": {
        "criterion_id": {
          "title": "Criterion Id",
          "type": "string"
        },
        "classification": {
          "enum": [
            "strong",
            "partial",
            "weak",
            "missing",
            "unknown"
          ],
          "title": "Classification",
          "type": "string"
        },
        "evidence_ref_ids": {
          "default": [],
          "items": {
            "type": "string"
          },
          "title": "Evidence Ref Ids",
          "type": "array"
        },
        "gaps": {
          "default": [],
          "items": {
            "$ref": "#/$defs/EvidenceGapV1"
          },
          "title": "Gaps",
          "type": "array"
        },
        "review_state": {
          "default": "proposed",
          "enum": [
            "proposed",
            "confirmed",
            "corrected"
          ],
          "title": "Review State",
          "type": "string"
        }
      },
      "required": [
        "criterion_id",
        "classification"
      ],
      "title": "CriterionMatchV1",
      "type": "object"
    },
    "EvidenceGapV1": {
      "additionalProperties": false,
      "properties": {
        "code": {
          "title": "Code",
          "type": "string"
        },
        "message": {
          "minLength": 1,
          "title": "Message",
          "type": "string"
        },
        "next_action": {
          "minLength": 1,
          "title": "Next Action",
          "type": "string"
        }
      },
      "required": [
        "code",
        "message",
        "next_action"
      ],
      "title": "EvidenceGapV1",
      "type": "object"
    },
    "EvidenceRefV1": {
      "additionalProperties": false,
      "properties": {
        "evidence_id": {
          "title": "Evidence Id",
          "type": "string"
        },
        "path": {
          "title": "Path",
          "type": "string"
        },
        "section": {
          "minLength": 1,
          "title": "Section",
          "type": "string"
        },
        "item_locator": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Item Locator"
        },
        "kind": {
          "minLength": 1,
          "title": "Kind",
          "type": "string"
        },
        "content_sha256": {
          "title": "Content Sha256",
          "type": "string"
        }
      },
      "required": [
        "evidence_id",
        "path",
        "section",
        "kind",
        "content_sha256"
      ],
      "title": "EvidenceRefV1",
      "type": "object"
    }
  },
  "$id": "https://github.com/jxpeng98/CanISend/schemas/criterion-matches.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "const": "1.0.0",
      "default": "1.0.0",
      "title": "Schema Version",
      "type": "string"
    },
    "job_id": {
      "title": "Job Id",
      "type": "string"
    },
    "input_fingerprint": {
      "title": "Input Fingerprint",
      "type": "string"
    },
    "criteria_catalog_sha256": {
      "title": "Criteria Catalog Sha256",
      "type": "string"
    },
    "evidence_catalog_sha256": {
      "title": "Evidence Catalog Sha256",
      "type": "string"
    },
    "matcher_strategy": {
      "title": "Matcher Strategy",
      "type": "string"
    },
    "matcher_version": {
      "title": "Matcher Version",
      "type": "string"
    },
    "evidence_refs": {
      "default": [],
      "items": {
        "$ref": "#/$defs/EvidenceRefV1"
      },
      "title": "Evidence Refs",
      "type": "array"
    },
    "matches": {
      "items": {
        "$ref": "#/$defs/CriterionMatchV1"
      },
      "title": "Matches",
      "type": "array"
    }
  },
  "required": [
    "job_id",
    "input_fingerprint",
    "criteria_catalog_sha256",
    "evidence_catalog_sha256",
    "matcher_strategy",
    "matcher_version",
    "matches"
  ],
  "title": "CanISendCriterionMatchesV1",
  "type": "object"
}
