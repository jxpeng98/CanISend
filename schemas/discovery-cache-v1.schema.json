{
  "$id": "https://github.com/jxpeng98/CanISend/schemas/discovery-cache-v1.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "protocol": {
      "const": "canisend.discovery-cache/v1",
      "default": "canisend.discovery-cache/v1",
      "title": "Protocol",
      "type": "string"
    },
    "schema_version": {
      "const": "1.0.0",
      "default": "1.0.0",
      "title": "Schema Version",
      "type": "string"
    },
    "source_id": {
      "pattern": "^[a-z](?:[a-z0-9._-]{0,62}[a-z0-9_])?$",
      "title": "Source Id",
      "type": "string"
    },
    "source_url": {
      "maxLength": 8192,
      "minLength": 1,
      "title": "Source Url",
      "type": "string"
    },
    "etag": {
      "default": "",
      "maxLength": 1024,
      "title": "Etag",
      "type": "string"
    },
    "last_modified": {
      "default": "",
      "maxLength": 1024,
      "title": "Last Modified",
      "type": "string"
    },
    "validated_at": {
      "format": "date-time",
      "title": "Validated At",
      "type": "string"
    },
    "content_sha256": {
      "pattern": "^[0-9a-f]{64}$",
      "title": "Content Sha256",
      "type": "string"
    }
  },
  "required": [
    "source_id",
    "source_url",
    "validated_at",
    "content_sha256"
  ],
  "title": "CanISendDiscoveryCacheV1",
  "type": "object"
}
