{
  "$id": "https://github.com/jxpeng98/CanISend/schemas/document-readiness.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "allOf": [
    {
      "if": {
        "properties": {
          "state": {
            "const": "blocked"
          }
        },
        "required": [
          "state"
        ]
      },
      "then": {
        "properties": {
          "blocker_finding_ids": {
            "minItems": 1
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "state": {
            "const": "revision_required"
          }
        },
        "required": [
          "state"
        ]
      },
      "then": {
        "properties": {
          "blocker_finding_ids": {
            "maxItems": 0
          },
          "revision_required_finding_ids": {
            "minItems": 1
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "state": {
            "const": "reviewed"
          }
        },
        "required": [
          "state"
        ]
      },
      "then": {
        "properties": {
          "review_dispositions_sha256": {
            "not": {
              "type": "null"
            }
          },
          "blocker_finding_ids": {
            "maxItems": 0
          },
          "revision_required_finding_ids": {
            "maxItems": 0
          },
          "unresolved_finding_ids": {
            "maxItems": 0
          },
          "reason_codes": {
            "maxItems": 0
          }
        }
      }
    }
  ],
  "properties": {
    "schema_version": {
      "const": "1.0.0",
      "default": "1.0.0",
      "title": "Schema Version",
      "type": "string"
    },
    "job_id": {
      "pattern": "^[a-z0-9][a-z0-9_.-]*$",
      "title": "Job Id",
      "type": "string"
    },
    "document_id": {
      "pattern": "^document_[0-9a-f]{32}$",
      "title": "Document Id",
      "type": "string"
    },
    "document_kind": {
      "const": "cover_letter",
      "default": "cover_letter",
      "title": "Document Kind",
      "type": "string"
    },
    "state": {
      "enum": [
        "blocked",
        "review_required",
        "revision_required",
        "reviewed"
      ],
      "title": "State",
      "type": "string"
    },
    "draft_sha256": {
      "pattern": "^[0-9a-f]{64}$",
      "title": "Draft Sha256",
      "type": "string"
    },
    "review_findings_sha256": {
      "pattern": "^[0-9a-f]{64}$",
      "title": "Review Findings Sha256",
      "type": "string"
    },
    "review_dispositions_sha256": {
      "anyOf": [
        {
          "pattern": "^[0-9a-f]{64}$",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Review Dispositions Sha256"
    },
    "accepted_finding_ids": {
      "default": [],
      "items": {
        "pattern": "^finding_[0-9a-f]{32}$",
        "type": "string"
      },
      "maxItems": 4096,
      "title": "Accepted Finding Ids",
      "type": "array",
      "uniqueItems": true
    },
    "revision_required_finding_ids": {
      "default": [],
      "items": {
        "pattern": "^finding_[0-9a-f]{32}$",
        "type": "string"
      },
      "maxItems": 4096,
      "title": "Revision Required Finding Ids",
      "type": "array",
      "uniqueItems": true
    },
    "unresolved_finding_ids": {
      "default": [],
      "items": {
        "pattern": "^finding_[0-9a-f]{32}$",
        "type": "string"
      },
      "maxItems": 4096,
      "title": "Unresolved Finding Ids",
      "type": "array",
      "uniqueItems": true
    },
    "blocker_finding_ids": {
      "default": [],
      "items": {
        "pattern": "^finding_[0-9a-f]{32}$",
        "type": "string"
      },
      "maxItems": 4096,
      "title": "Blocker Finding Ids",
      "type": "array",
      "uniqueItems": true
    },
    "reason_codes": {
      "default": [],
      "items": {
        "pattern": "^[a-z][a-z0-9_-]*(?:\\.[a-z][a-z0-9_-]*)+$",
        "type": "string"
      },
      "maxItems": 64,
      "title": "Reason Codes",
      "type": "array",
      "uniqueItems": true
    }
  },
  "required": [
    "job_id",
    "document_id",
    "state",
    "draft_sha256",
    "review_findings_sha256"
  ],
  "title": "CanISendDocumentReadinessV1",
  "type": "object"
}
