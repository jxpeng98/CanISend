{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "FitReport",
  "type": "object",
  "required": ["summary", "strengths", "gaps", "risks"],
  "properties": {
    "summary": {"type": "string"},
    "strengths": {"type": "array", "items": {"type": "string"}},
    "gaps": {"type": "array", "items": {"type": "string"}},
    "risks": {"type": "array", "items": {"type": "string"}}
  }
}
