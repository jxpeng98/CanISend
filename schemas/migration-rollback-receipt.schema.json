{
  "$defs": {
    "RollbackEntryV1": {
      "additionalProperties": false,
      "properties": {
        "expected_after_sha256": {
          "title": "Expected After Sha256",
          "type": "string"
        },
        "observed_sha256": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Observed Sha256"
        },
        "outcome": {
          "enum": [
            "removed",
            "restored",
            "already_rolled_back",
            "conflict"
          ],
          "title": "Outcome",
          "type": "string"
        },
        "path": {
          "title": "Path",
          "type": "string"
        },
        "restored_sha256": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Restored Sha256"
        }
      },
      "required": [
        "path",
        "outcome",
        "expected_after_sha256"
      ],
      "title": "RollbackEntryV1",
      "type": "object"
    }
  },
  "$id": "https://github.com/jxpeng98/CanISend/schemas/migration-rollback-receipt.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "completed_at": {
      "format": "date-time",
      "title": "Completed At",
      "type": "string"
    },
    "entries": {
      "items": {
        "$ref": "#/$defs/RollbackEntryV1"
      },
      "title": "Entries",
      "type": "array"
    },
    "job_id": {
      "title": "Job Id",
      "type": "string"
    },
    "migration_id": {
      "const": "stage5-v1",
      "default": "stage5-v1",
      "title": "Migration Id",
      "type": "string"
    },
    "migration_receipt_sha256": {
      "title": "Migration Receipt Sha256",
      "type": "string"
    },
    "rollback_id": {
      "title": "Rollback Id",
      "type": "string"
    },
    "schema_version": {
      "const": "1.0.0",
      "default": "1.0.0",
      "title": "Schema Version",
      "type": "string"
    },
    "status": {
      "enum": [
        "complete",
        "conflict"
      ],
      "title": "Status",
      "type": "string"
    }
  },
  "required": [
    "rollback_id",
    "job_id",
    "completed_at",
    "status",
    "migration_receipt_sha256",
    "entries"
  ],
  "title": "MigrationRollbackReceiptV1",
  "type": "object"
}
