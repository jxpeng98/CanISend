{
  "$defs": {
    "PackageCorrectionProposalV1": {
      "additionalProperties": false,
      "properties": {
        "proposal_id": {
          "pattern": "^proposal_[0-9a-f]{32}$",
          "title": "Proposal Id",
          "type": "string"
        },
        "document_id": {
          "pattern": "^document_[0-9a-f]{32}$",
          "title": "Document Id",
          "type": "string"
        },
        "claim_ids": {
          "items": {
            "pattern": "^claim_[0-9a-f]{32}$",
            "type": "string"
          },
          "maxItems": 4096,
          "minItems": 1,
          "title": "Claim Ids",
          "type": "array",
          "uniqueItems": true
        },
        "reason_code": {
          "pattern": "^[a-z][a-z0-9_-]*(?:\\.[a-z][a-z0-9_-]*)+$",
          "title": "Reason Code",
          "type": "string"
        },
        "instruction": {
          "maxLength": 10000,
          "minLength": 1,
          "pattern": "[\\s\\S]*\\S[\\s\\S]*",
          "title": "Instruction",
          "type": "string"
        },
        "application_route": {
          "const": "guarded_draft_candidate",
          "default": "guarded_draft_candidate",
          "title": "Application Route",
          "type": "string"
        }
      },
      "required": [
        "proposal_id",
        "document_id",
        "claim_ids",
        "reason_code",
        "instruction"
      ],
      "title": "PackageCorrectionProposalV1",
      "type": "object"
    },
    "PackageDocumentReviewV1": {
      "additionalProperties": false,
      "allOf": [
        {
          "if": {
            "properties": {
              "action": {
                "const": "omit"
              }
            },
            "required": [
              "action"
            ]
          },
          "then": {
            "properties": {
              "state": {
                "const": "omitted"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "state": {
                "const": "omitted"
              }
            },
            "required": [
              "state"
            ]
          },
          "then": {
            "properties": {
              "action": {
                "const": "omit"
              },
              "draft_sha256": {
                "type": "null"
              },
              "review_findings_sha256": {
                "type": "null"
              },
              "review_dispositions_sha256": {
                "type": "null"
              },
              "document_readiness_sha256": {
                "type": "null"
              },
              "readiness_state": {
                "type": "null"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "state": {
                "const": "plan_blocked"
              }
            },
            "required": [
              "state"
            ]
          },
          "then": {
            "properties": {
              "action": {
                "const": "prepare"
              },
              "draft_sha256": {
                "type": "null"
              },
              "review_findings_sha256": {
                "type": "null"
              },
              "review_dispositions_sha256": {
                "type": "null"
              },
              "document_readiness_sha256": {
                "type": "null"
              },
              "readiness_state": {
                "type": "null"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "state": {
                "const": "executor_unavailable"
              }
            },
            "required": [
              "state"
            ]
          },
          "then": {
            "properties": {
              "action": {
                "const": "prepare"
              },
              "executor_availability": {
                "enum": [
                  "planned",
                  "unregistered"
                ]
              },
              "draft_sha256": {
                "type": "null"
              },
              "review_findings_sha256": {
                "type": "null"
              },
              "review_dispositions_sha256": {
                "type": "null"
              },
              "document_readiness_sha256": {
                "type": "null"
              },
              "readiness_state": {
                "type": "null"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "state": {
                "const": "draft_missing"
              }
            },
            "required": [
              "state"
            ]
          },
          "then": {
            "properties": {
              "action": {
                "const": "prepare"
              },
              "executor_availability": {
                "const": "available"
              },
              "draft_sha256": {
                "type": "null"
              },
              "review_findings_sha256": {
                "type": "null"
              },
              "review_dispositions_sha256": {
                "type": "null"
              },
              "document_readiness_sha256": {
                "type": "null"
              },
              "readiness_state": {
                "type": "null"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "state": {
                "enum": [
                  "draft_not_current",
                  "review_missing"
                ]
              }
            },
            "required": [
              "state"
            ]
          },
          "then": {
            "properties": {
              "action": {
                "const": "prepare"
              },
              "executor_availability": {
                "const": "available"
              },
              "draft_sha256": {
                "not": {
                  "type": "null"
                }
              },
              "review_findings_sha256": {
                "type": "null"
              },
              "review_dispositions_sha256": {
                "type": "null"
              },
              "document_readiness_sha256": {
                "type": "null"
              },
              "readiness_state": {
                "type": "null"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "state": {
                "const": "review_not_current"
              }
            },
            "required": [
              "state"
            ]
          },
          "then": {
            "properties": {
              "action": {
                "const": "prepare"
              },
              "executor_availability": {
                "const": "available"
              },
              "draft_sha256": {
                "not": {
                  "type": "null"
                }
              },
              "review_findings_sha256": {
                "not": {
                  "type": "null"
                }
              },
              "review_dispositions_sha256": {
                "type": "null"
              },
              "document_readiness_sha256": {
                "type": "null"
              },
              "readiness_state": {
                "type": "null"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "state": {
                "const": "blocked"
              }
            },
            "required": [
              "state"
            ]
          },
          "then": {
            "properties": {
              "action": {
                "const": "prepare"
              },
              "executor_availability": {
                "const": "available"
              },
              "draft_sha256": {
                "not": {
                  "type": "null"
                }
              },
              "review_findings_sha256": {
                "not": {
                  "type": "null"
                }
              },
              "document_readiness_sha256": {
                "not": {
                  "type": "null"
                }
              },
              "readiness_state": {
                "const": "blocked"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "state": {
                "const": "review_required"
              }
            },
            "required": [
              "state"
            ]
          },
          "then": {
            "properties": {
              "action": {
                "const": "prepare"
              },
              "executor_availability": {
                "const": "available"
              },
              "draft_sha256": {
                "not": {
                  "type": "null"
                }
              },
              "review_findings_sha256": {
                "not": {
                  "type": "null"
                }
              },
              "document_readiness_sha256": {
                "not": {
                  "type": "null"
                }
              },
              "readiness_state": {
                "const": "review_required"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "state": {
                "const": "revision_required"
              }
            },
            "required": [
              "state"
            ]
          },
          "then": {
            "properties": {
              "action": {
                "const": "prepare"
              },
              "executor_availability": {
                "const": "available"
              },
              "draft_sha256": {
                "not": {
                  "type": "null"
                }
              },
              "review_findings_sha256": {
                "not": {
                  "type": "null"
                }
              },
              "document_readiness_sha256": {
                "not": {
                  "type": "null"
                }
              },
              "readiness_state": {
                "const": "revision_required"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "state": {
                "const": "reviewed"
              }
            },
            "required": [
              "state"
            ]
          },
          "then": {
            "properties": {
              "action": {
                "const": "prepare"
              },
              "executor_availability": {
                "const": "available"
              },
              "draft_sha256": {
                "not": {
                  "type": "null"
                }
              },
              "review_findings_sha256": {
                "not": {
                  "type": "null"
                }
              },
              "document_readiness_sha256": {
                "not": {
                  "type": "null"
                }
              },
              "readiness_state": {
                "const": "reviewed"
              }
            }
          }
        },
        {
          "else": {
            "properties": {
              "reason_codes": {
                "minItems": 1
              }
            }
          },
          "if": {
            "properties": {
              "state": {
                "const": "reviewed"
              }
            },
            "required": [
              "state"
            ]
          },
          "then": {
            "properties": {
              "review_dispositions_sha256": {
                "not": {
                  "type": "null"
                }
              },
              "reason_codes": {
                "maxItems": 0
              }
            }
          }
        }
      ],
      "properties": {
        "document_id": {
          "pattern": "^document_[0-9a-f]{32}$",
          "title": "Document Id",
          "type": "string"
        },
        "normalized_kind": {
          "pattern": "^[a-z][a-z0-9_]*$",
          "title": "Normalized Kind",
          "type": "string"
        },
        "requirement": {
          "enum": [
            "required",
            "optional",
            "unknown"
          ],
          "title": "Requirement",
          "type": "string"
        },
        "action": {
          "enum": [
            "prepare",
            "omit",
            "needs_confirmation"
          ],
          "title": "Action",
          "type": "string"
        },
        "executor_availability": {
          "enum": [
            "available",
            "planned",
            "unregistered"
          ],
          "title": "Executor Availability",
          "type": "string"
        },
        "state": {
          "enum": [
            "omitted",
            "plan_blocked",
            "executor_unavailable",
            "draft_missing",
            "draft_not_current",
            "review_missing",
            "review_not_current",
            "blocked",
            "review_required",
            "revision_required",
            "reviewed"
          ],
          "title": "State",
          "type": "string"
        },
        "draft_sha256": {
          "anyOf": [
            {
              "pattern": "^[0-9a-f]{64}$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Draft Sha256"
        },
        "review_findings_sha256": {
          "anyOf": [
            {
              "pattern": "^[0-9a-f]{64}$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Review Findings Sha256"
        },
        "review_dispositions_sha256": {
          "anyOf": [
            {
              "pattern": "^[0-9a-f]{64}$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Review Dispositions Sha256"
        },
        "document_readiness_sha256": {
          "anyOf": [
            {
              "pattern": "^[0-9a-f]{64}$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Document Readiness Sha256"
        },
        "readiness_state": {
          "anyOf": [
            {
              "enum": [
                "blocked",
                "review_required",
                "revision_required",
                "reviewed"
              ],
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Readiness State"
        },
        "claim_ids": {
          "default": [],
          "items": {
            "pattern": "^claim_[0-9a-f]{32}$",
            "type": "string"
          },
          "maxItems": 4096,
          "title": "Claim Ids",
          "type": "array",
          "uniqueItems": true
        },
        "reason_codes": {
          "default": [],
          "items": {
            "pattern": "^[a-z][a-z0-9_-]*(?:\\.[a-z][a-z0-9_-]*)+$",
            "type": "string"
          },
          "maxItems": 64,
          "title": "Reason Codes",
          "type": "array",
          "uniqueItems": true
        }
      },
      "required": [
        "document_id",
        "normalized_kind",
        "requirement",
        "action",
        "executor_availability",
        "state"
      ],
      "title": "PackageDocumentReviewV1",
      "type": "object"
    },
    "PackageReviewFindingV1": {
      "additionalProperties": false,
      "properties": {
        "finding_id": {
          "pattern": "^finding_[0-9a-f]{32}$",
          "title": "Finding Id",
          "type": "string"
        },
        "code": {
          "pattern": "^[a-z][a-z0-9_-]*(?:\\.[a-z][a-z0-9_-]*)+$",
          "title": "Code",
          "type": "string"
        },
        "severity": {
          "enum": [
            "blocker",
            "review",
            "warning"
          ],
          "title": "Severity",
          "type": "string"
        },
        "category": {
          "enum": [
            "support",
            "contradiction",
            "consistency",
            "completeness",
            "compliance",
            "style"
          ],
          "title": "Category",
          "type": "string"
        },
        "message": {
          "maxLength": 10000,
          "minLength": 1,
          "pattern": "[\\s\\S]*\\S[\\s\\S]*",
          "title": "Message",
          "type": "string"
        },
        "next_action": {
          "maxLength": 10000,
          "minLength": 1,
          "pattern": "[\\s\\S]*\\S[\\s\\S]*",
          "title": "Next Action",
          "type": "string"
        },
        "document_ids": {
          "default": [],
          "items": {
            "pattern": "^document_[0-9a-f]{32}$",
            "type": "string"
          },
          "maxItems": 4096,
          "title": "Document Ids",
          "type": "array",
          "uniqueItems": true
        },
        "claim_ids": {
          "default": [],
          "items": {
            "pattern": "^claim_[0-9a-f]{32}$",
            "type": "string"
          },
          "maxItems": 4096,
          "title": "Claim Ids",
          "type": "array",
          "uniqueItems": true
        },
        "evidence_ref_ids": {
          "default": [],
          "items": {
            "pattern": "^evidence_[0-9a-f]{32}$",
            "type": "string"
          },
          "maxItems": 4096,
          "title": "Evidence Ref Ids",
          "type": "array",
          "uniqueItems": true
        },
        "correction_proposal_ids": {
          "default": [],
          "items": {
            "pattern": "^proposal_[0-9a-f]{32}$",
            "type": "string"
          },
          "maxItems": 4096,
          "title": "Correction Proposal Ids",
          "type": "array",
          "uniqueItems": true
        },
        "status": {
          "const": "open",
          "default": "open",
          "title": "Status",
          "type": "string"
        }
      },
      "required": [
        "finding_id",
        "code",
        "severity",
        "category",
        "message",
        "next_action"
      ],
      "title": "PackageReviewFindingV1",
      "type": "object"
    }
  },
  "$id": "https://github.com/jxpeng98/CanISend/schemas/package-review-findings.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "const": "1.0.0",
      "default": "1.0.0",
      "title": "Schema Version",
      "type": "string"
    },
    "job_id": {
      "pattern": "^[a-z0-9][a-z0-9_.-]*$",
      "title": "Job Id",
      "type": "string"
    },
    "input_fingerprint": {
      "pattern": "^[0-9a-f]{64}$",
      "title": "Input Fingerprint",
      "type": "string"
    },
    "parsed_job_sha256": {
      "pattern": "^[0-9a-f]{64}$",
      "title": "Parsed Job Sha256",
      "type": "string"
    },
    "application_brief_sha256": {
      "pattern": "^[0-9a-f]{64}$",
      "title": "Application Brief Sha256",
      "type": "string"
    },
    "required_document_plan_sha256": {
      "pattern": "^[0-9a-f]{64}$",
      "title": "Required Document Plan Sha256",
      "type": "string"
    },
    "document_execution_plan_sha256": {
      "pattern": "^[0-9a-f]{64}$",
      "title": "Document Execution Plan Sha256",
      "type": "string"
    },
    "reviewer_strategy": {
      "pattern": "^[a-z][a-z0-9_-]*(?:\\.[a-z][a-z0-9_-]*)+$",
      "title": "Reviewer Strategy",
      "type": "string"
    },
    "reviewer_version": {
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+(?:[-+][0-9A-Za-z.-]+)?$",
      "title": "Reviewer Version",
      "type": "string"
    },
    "review_state": {
      "const": "proposed",
      "default": "proposed",
      "title": "Review State",
      "type": "string"
    },
    "documents": {
      "default": [],
      "items": {
        "$ref": "#/$defs/PackageDocumentReviewV1"
      },
      "maxItems": 4096,
      "title": "Documents",
      "type": "array",
      "uniqueItems": true
    },
    "required_document_ids": {
      "default": [],
      "items": {
        "pattern": "^document_[0-9a-f]{32}$",
        "type": "string"
      },
      "maxItems": 4096,
      "title": "Required Document Ids",
      "type": "array",
      "uniqueItems": true
    },
    "selected_document_ids": {
      "default": [],
      "items": {
        "pattern": "^document_[0-9a-f]{32}$",
        "type": "string"
      },
      "maxItems": 4096,
      "title": "Selected Document Ids",
      "type": "array",
      "uniqueItems": true
    },
    "reviewed_document_ids": {
      "default": [],
      "items": {
        "pattern": "^document_[0-9a-f]{32}$",
        "type": "string"
      },
      "maxItems": 4096,
      "title": "Reviewed Document Ids",
      "type": "array",
      "uniqueItems": true
    },
    "findings": {
      "default": [],
      "items": {
        "$ref": "#/$defs/PackageReviewFindingV1"
      },
      "maxItems": 4096,
      "title": "Findings",
      "type": "array",
      "uniqueItems": true
    },
    "correction_proposals": {
      "default": [],
      "items": {
        "$ref": "#/$defs/PackageCorrectionProposalV1"
      },
      "maxItems": 4096,
      "title": "Correction Proposals",
      "type": "array",
      "uniqueItems": true
    },
    "blocker_finding_ids": {
      "default": [],
      "items": {
        "pattern": "^finding_[0-9a-f]{32}$",
        "type": "string"
      },
      "maxItems": 4096,
      "title": "Blocker Finding Ids",
      "type": "array",
      "uniqueItems": true
    }
  },
  "required": [
    "job_id",
    "input_fingerprint",
    "parsed_job_sha256",
    "application_brief_sha256",
    "required_document_plan_sha256",
    "document_execution_plan_sha256",
    "reviewer_strategy",
    "reviewer_version"
  ],
  "title": "CanISendPackageReviewFindingsV1",
  "type": "object"
}
