{
  "$defs": {
    "DocumentRequirementV1": {
      "additionalProperties": false,
      "allOf": [
        {
          "else": {
            "properties": {
              "source_text": {
                "type": "null"
              },
              "source_span": {
                "type": "null"
              },
              "unknown_reason": {
                "not": {
                  "type": "null"
                }
              }
            },
            "required": [
              "unknown_reason"
            ]
          },
          "if": {
            "properties": {
              "source_state": {
                "const": "known"
              }
            },
            "required": [
              "source_state"
            ]
          },
          "then": {
            "properties": {
              "source_text": {
                "minLength": 1,
                "pattern": "[\\s\\S]*\\S[\\s\\S]*",
                "type": "string"
              },
              "source_span": {
                "not": {
                  "type": "null"
                },
                "properties": {
                  "text_sha256": {
                    "pattern": "^[0-9a-f]{64}$",
                    "type": "string"
                  },
                  "anchor_sha256": {
                    "pattern": "^[0-9a-f]{64}$",
                    "type": "string"
                  }
                }
              },
              "unknown_reason": {
                "type": "null"
              }
            },
            "required": [
              "source_text",
              "source_span"
            ]
          }
        }
      ],
      "properties": {
        "document_id": {
          "pattern": "^document_[0-9a-f]{32}$",
          "title": "Document Id",
          "type": "string"
        },
        "label": {
          "maxLength": 10000,
          "minLength": 1,
          "pattern": "[\\s\\S]*\\S[\\s\\S]*",
          "title": "Label",
          "type": "string"
        },
        "normalized_kind": {
          "pattern": "^[a-z][a-z0-9_]*$",
          "title": "Normalized Kind",
          "type": "string"
        },
        "requirement": {
          "enum": [
            "required",
            "optional",
            "unknown"
          ],
          "title": "Requirement",
          "type": "string"
        },
        "source_text": {
          "anyOf": [
            {
              "maxLength": 200000,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Source Text"
        },
        "source_state": {
          "enum": [
            "known",
            "unknown"
          ],
          "title": "Source State",
          "type": "string"
        },
        "source_span": {
          "anyOf": [
            {
              "$ref": "#/$defs/SourceSpanV1"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "confirmation_state": {
          "default": "unconfirmed",
          "enum": [
            "unconfirmed",
            "confirmed"
          ],
          "title": "Confirmation State",
          "type": "string"
        },
        "unknown_reason": {
          "anyOf": [
            {
              "pattern": "^[a-z][a-z0-9_-]*(?:\\.[a-z][a-z0-9_-]*)*$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Unknown Reason"
        }
      },
      "required": [
        "document_id",
        "label",
        "normalized_kind",
        "requirement",
        "source_state"
      ],
      "title": "DocumentRequirementV1",
      "type": "object"
    },
    "DocumentTaskV1": {
      "additionalProperties": false,
      "allOf": [
        {
          "else": {
            "properties": {
              "confirmation_state": {
                "const": "confirmed"
              }
            }
          },
          "if": {
            "properties": {
              "action": {
                "const": "needs_confirmation"
              }
            },
            "required": [
              "action"
            ]
          },
          "then": {
            "properties": {
              "confirmation_state": {
                "const": "unconfirmed"
              },
              "blockers": {
                "minItems": 1
              }
            },
            "required": [
              "confirmation_state",
              "blockers"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "action": {
                "const": "prepare"
              }
            },
            "required": [
              "action"
            ]
          },
          "then": {
            "properties": {
              "blockers": {
                "maxItems": 0
              }
            }
          }
        }
      ],
      "properties": {
        "document_id": {
          "pattern": "^document_[0-9a-f]{32}$",
          "title": "Document Id",
          "type": "string"
        },
        "action": {
          "enum": [
            "prepare",
            "omit",
            "needs_confirmation"
          ],
          "title": "Action",
          "type": "string"
        },
        "confirmation_state": {
          "enum": [
            "unconfirmed",
            "confirmed"
          ],
          "title": "Confirmation State",
          "type": "string"
        },
        "blockers": {
          "default": [],
          "items": {
            "pattern": "^[a-z][a-z0-9_-]*(?:\\.[a-z][a-z0-9_-]*)+$",
            "type": "string"
          },
          "title": "Blockers",
          "type": "array",
          "uniqueItems": true
        }
      },
      "required": [
        "document_id",
        "action",
        "confirmation_state"
      ],
      "title": "DocumentTaskV1",
      "type": "object"
    },
    "SourceSpanV1": {
      "additionalProperties": false,
      "properties": {
        "path": {
          "title": "Path",
          "type": "string"
        },
        "start_line": {
          "minimum": 1,
          "title": "Start Line",
          "type": "integer"
        },
        "end_line": {
          "minimum": 1,
          "title": "End Line",
          "type": "integer"
        },
        "text_sha256": {
          "title": "Text Sha256",
          "type": "string"
        },
        "anchor_sha256": {
          "title": "Anchor Sha256",
          "type": "string"
        },
        "occurrence": {
          "minimum": 1,
          "title": "Occurrence",
          "type": "integer"
        },
        "occurrence_count": {
          "minimum": 1,
          "title": "Occurrence Count",
          "type": "integer"
        }
      },
      "required": [
        "path",
        "start_line",
        "end_line",
        "text_sha256",
        "anchor_sha256",
        "occurrence",
        "occurrence_count"
      ],
      "title": "SourceSpanV1",
      "type": "object"
    }
  },
  "$id": "https://github.com/jxpeng98/CanISend/schemas/required-document-plan.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "allOf": [
    {
      "if": {
        "properties": {
          "requirements_state": {
            "const": "confirmed_empty"
          }
        },
        "required": [
          "requirements_state"
        ]
      },
      "then": {
        "properties": {
          "requirements": {
            "maxItems": 0
          },
          "tasks": {
            "maxItems": 0
          },
          "unresolved_document_ids": {
            "maxItems": 0
          },
          "blocking_document_ids": {
            "maxItems": 0
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "requirements_state": {
            "const": "confirmed"
          }
        },
        "required": [
          "requirements_state"
        ]
      },
      "then": {
        "properties": {
          "requirements": {
            "items": {
              "properties": {
                "confirmation_state": {
                  "const": "confirmed"
                },
                "source_state": {
                  "const": "known"
                }
              },
              "required": [
                "confirmation_state",
                "source_state"
              ]
            },
            "minItems": 1
          }
        }
      }
    },
    {
      "if": {
        "not": {
          "properties": {
            "requirements_state": {
              "enum": [
                "confirmed",
                "confirmed_empty"
              ]
            }
          },
          "required": [
            "requirements_state"
          ]
        }
      },
      "then": {
        "allOf": [
          {
            "if": {
              "properties": {
                "requirements": {
                  "minItems": 1
                }
              },
              "required": [
                "requirements"
              ]
            },
            "then": {
              "required": [
                "unresolved_document_ids",
                "blocking_document_ids"
              ]
            }
          }
        ],
        "properties": {
          "requirements": {
            "items": {
              "properties": {
                "confirmation_state": {
                  "const": "unconfirmed"
                }
              }
            }
          },
          "tasks": {
            "items": {
              "properties": {
                "action": {
                  "const": "needs_confirmation"
                }
              }
            }
          },
          "blockers": {
            "contains": {
              "const": "documents.requirements_unconfirmed"
            }
          }
        },
        "required": [
          "blockers"
        ]
      }
    }
  ],
  "properties": {
    "schema_version": {
      "const": "1.0.0",
      "default": "1.0.0",
      "title": "Schema Version",
      "type": "string"
    },
    "job_id": {
      "pattern": "^[a-z0-9][a-z0-9_.-]*$",
      "title": "Job Id",
      "type": "string"
    },
    "input_fingerprint": {
      "pattern": "^[0-9a-f]{64}$",
      "title": "Input Fingerprint",
      "type": "string"
    },
    "requirements_state": {
      "default": "unconfirmed",
      "enum": [
        "unconfirmed",
        "confirmed",
        "confirmed_empty"
      ],
      "title": "Requirements State",
      "type": "string"
    },
    "requirements_basis_sha256": {
      "pattern": "^[0-9a-f]{64}$",
      "title": "Requirements Basis Sha256",
      "type": "string"
    },
    "requirements": {
      "items": {
        "$ref": "#/$defs/DocumentRequirementV1"
      },
      "title": "Requirements",
      "type": "array",
      "uniqueItems": true
    },
    "tasks": {
      "items": {
        "$ref": "#/$defs/DocumentTaskV1"
      },
      "title": "Tasks",
      "type": "array",
      "uniqueItems": true
    },
    "unresolved_brief_fields": {
      "default": [],
      "items": {
        "enum": [
          "language",
          "writing_style",
          "motivation",
          "emphasis",
          "exclusions",
          "document_requirements"
        ],
        "type": "string"
      },
      "title": "Unresolved Brief Fields",
      "type": "array",
      "uniqueItems": true
    },
    "unresolved_document_ids": {
      "default": [],
      "items": {
        "pattern": "^document_[0-9a-f]{32}$",
        "type": "string"
      },
      "title": "Unresolved Document Ids",
      "type": "array",
      "uniqueItems": true
    },
    "blocking_document_ids": {
      "default": [],
      "items": {
        "pattern": "^document_[0-9a-f]{32}$",
        "type": "string"
      },
      "title": "Blocking Document Ids",
      "type": "array",
      "uniqueItems": true
    },
    "orphaned_document_choice_ids": {
      "default": [],
      "items": {
        "pattern": "^document_[0-9a-f]{32}$",
        "type": "string"
      },
      "title": "Orphaned Document Choice Ids",
      "type": "array",
      "uniqueItems": true
    },
    "blockers": {
      "default": [],
      "items": {
        "pattern": "^[a-z][a-z0-9_-]*(?:\\.[a-z][a-z0-9_-]*)+$",
        "type": "string"
      },
      "title": "Blockers",
      "type": "array",
      "uniqueItems": true
    }
  },
  "required": [
    "job_id",
    "input_fingerprint",
    "requirements_basis_sha256",
    "requirements",
    "tasks"
  ],
  "title": "CanISendRequiredDocumentPlanV1",
  "type": "object"
}
