{
  "$defs": {
    "FindingDispositionV1": {
      "additionalProperties": false,
      "properties": {
        "finding_id": {
          "pattern": "^finding_[0-9a-f]{32}$",
          "title": "Finding Id",
          "type": "string"
        },
        "disposition": {
          "enum": [
            "accepted",
            "revision_required"
          ],
          "title": "Disposition",
          "type": "string"
        },
        "decided_at": {
          "format": "date-time",
          "title": "Decided At",
          "type": "string"
        }
      },
      "required": [
        "finding_id",
        "disposition",
        "decided_at"
      ],
      "title": "FindingDispositionV1",
      "type": "object"
    }
  },
  "$id": "https://github.com/jxpeng98/CanISend/schemas/review-dispositions.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "const": "1.0.0",
      "default": "1.0.0",
      "title": "Schema Version",
      "type": "string"
    },
    "job_id": {
      "pattern": "^[a-z0-9][a-z0-9_.-]*$",
      "title": "Job Id",
      "type": "string"
    },
    "document_id": {
      "pattern": "^document_[0-9a-f]{32}$",
      "title": "Document Id",
      "type": "string"
    },
    "revision": {
      "maximum": 9223372036854775807,
      "minimum": 0,
      "title": "Revision",
      "type": "integer"
    },
    "updated_at": {
      "format": "date-time",
      "title": "Updated At",
      "type": "string"
    },
    "draft_sha256": {
      "pattern": "^[0-9a-f]{64}$",
      "title": "Draft Sha256",
      "type": "string"
    },
    "review_findings_sha256": {
      "pattern": "^[0-9a-f]{64}$",
      "title": "Review Findings Sha256",
      "type": "string"
    },
    "dispositions": {
      "default": [],
      "items": {
        "$ref": "#/$defs/FindingDispositionV1"
      },
      "maxItems": 4096,
      "title": "Dispositions",
      "type": "array",
      "uniqueItems": true
    }
  },
  "required": [
    "job_id",
    "document_id",
    "revision",
    "updated_at",
    "draft_sha256",
    "review_findings_sha256"
  ],
  "title": "CanISendReviewDispositionsV1",
  "type": "object"
}
