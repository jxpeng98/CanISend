{
  "$defs": {
    "ReviewFindingV1": {
      "additionalProperties": false,
      "properties": {
        "finding_id": {
          "pattern": "^finding_[0-9a-f]{32}$",
          "title": "Finding Id",
          "type": "string"
        },
        "code": {
          "pattern": "^[a-z][a-z0-9_-]*(?:\\.[a-z][a-z0-9_-]*)+$",
          "title": "Code",
          "type": "string"
        },
        "severity": {
          "enum": [
            "blocker",
            "review",
            "warning"
          ],
          "title": "Severity",
          "type": "string"
        },
        "category": {
          "enum": [
            "support",
            "contradiction",
            "consistency",
            "completeness",
            "compliance",
            "style"
          ],
          "title": "Category",
          "type": "string"
        },
        "message": {
          "maxLength": 10000,
          "minLength": 1,
          "pattern": "[\\s\\S]*\\S[\\s\\S]*",
          "title": "Message",
          "type": "string"
        },
        "next_action": {
          "maxLength": 10000,
          "minLength": 1,
          "pattern": "[\\s\\S]*\\S[\\s\\S]*",
          "title": "Next Action",
          "type": "string"
        },
        "claim_ids": {
          "default": [],
          "items": {
            "pattern": "^claim_[0-9a-f]{32}$",
            "type": "string"
          },
          "maxItems": 4096,
          "title": "Claim Ids",
          "type": "array",
          "uniqueItems": true
        },
        "criterion_ids": {
          "default": [],
          "items": {
            "pattern": "^criterion_[0-9a-f]{32}$",
            "type": "string"
          },
          "maxItems": 4096,
          "title": "Criterion Ids",
          "type": "array",
          "uniqueItems": true
        },
        "evidence_ref_ids": {
          "default": [],
          "items": {
            "pattern": "^evidence_[0-9a-f]{32}$",
            "type": "string"
          },
          "maxItems": 4096,
          "title": "Evidence Ref Ids",
          "type": "array",
          "uniqueItems": true
        },
        "status": {
          "const": "open",
          "default": "open",
          "title": "Status",
          "type": "string"
        }
      },
      "required": [
        "finding_id",
        "code",
        "severity",
        "category",
        "message",
        "next_action"
      ],
      "title": "ReviewFindingV1",
      "type": "object"
    }
  },
  "$id": "https://github.com/jxpeng98/CanISend/schemas/review-findings.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "const": "1.0.0",
      "default": "1.0.0",
      "title": "Schema Version",
      "type": "string"
    },
    "job_id": {
      "pattern": "^[a-z0-9][a-z0-9_.-]*$",
      "title": "Job Id",
      "type": "string"
    },
    "document_id": {
      "pattern": "^document_[0-9a-f]{32}$",
      "title": "Document Id",
      "type": "string"
    },
    "input_fingerprint": {
      "pattern": "^[0-9a-f]{64}$",
      "title": "Input Fingerprint",
      "type": "string"
    },
    "draft_sha256": {
      "pattern": "^[0-9a-f]{64}$",
      "title": "Draft Sha256",
      "type": "string"
    },
    "reviewer_strategy": {
      "pattern": "^[a-z][a-z0-9_-]*(?:\\.[a-z][a-z0-9_-]*)+$",
      "title": "Reviewer Strategy",
      "type": "string"
    },
    "reviewer_version": {
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+(?:[-+][0-9A-Za-z.-]+)?$",
      "title": "Reviewer Version",
      "type": "string"
    },
    "review_state": {
      "const": "proposed",
      "default": "proposed",
      "title": "Review State",
      "type": "string"
    },
    "findings": {
      "default": [],
      "items": {
        "$ref": "#/$defs/ReviewFindingV1"
      },
      "maxItems": 4096,
      "title": "Findings",
      "type": "array",
      "uniqueItems": true
    },
    "blocker_finding_ids": {
      "default": [],
      "items": {
        "pattern": "^finding_[0-9a-f]{32}$",
        "type": "string"
      },
      "maxItems": 4096,
      "title": "Blocker Finding Ids",
      "type": "array",
      "uniqueItems": true
    }
  },
  "required": [
    "job_id",
    "document_id",
    "input_fingerprint",
    "draft_sha256",
    "reviewer_strategy",
    "reviewer_version"
  ],
  "title": "CanISendReviewFindingsV1",
  "type": "object"
}
