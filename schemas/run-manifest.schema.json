{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/jxpeng98/CanISend/schemas/run-manifest.schema.json",
  "title": "CanISendRunManifestV1",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "schema_version": { "enum": ["1.0.0", "1.1.0"], "default": "1.1.0" },
    "run_id": { "$ref": "#/$defs/runId" },
    "task_id": {
      "oneOf": [
        { "$ref": "#/$defs/taskId" },
        { "type": "null" }
      ]
    },
    "job_id": { "$ref": "#/$defs/jobId" },
    "stage": { "$ref": "#/$defs/stageName" },
    "document_id": {
      "oneOf": [
        { "$ref": "#/$defs/documentId" },
        { "type": "null" }
      ],
      "default": null
    },
    "attempt": { "type": "integer", "minimum": 1 },
    "execution_mode": {
      "enum": ["deterministic", "host_agent", "configured_provider"]
    },
    "status": {
      "enum": ["prepared", "running", "succeeded", "failed", "cancelled"]
    },
    "created_at": { "type": "string", "format": "date-time" },
    "started_at": {
      "oneOf": [
        { "type": "string", "format": "date-time" },
        { "type": "null" }
      ]
    },
    "completed_at": {
      "oneOf": [
        { "type": "string", "format": "date-time" },
        { "type": "null" }
      ]
    },
    "inputs": {
      "type": "array",
      "items": { "$ref": "#/$defs/artifactFingerprint" },
      "uniqueItems": true
    },
    "input_fingerprint": { "$ref": "#/$defs/sha256" },
    "task_spec_sha256": { "$ref": "#/$defs/sha256" },
    "candidate_outputs": {
      "type": "array",
      "items": { "$ref": "#/$defs/artifactFingerprint" },
      "uniqueItems": true
    },
    "promoted_outputs": {
      "type": "array",
      "items": { "$ref": "#/$defs/artifactFingerprint" },
      "uniqueItems": true
    },
    "validation_report_path": {
      "oneOf": [
        { "$ref": "#/$defs/jobPath" },
        { "type": "null" }
      ]
    },
    "error_code": {
      "oneOf": [
        {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_-]*(\\.[a-z][a-z0-9_-]*)+$"
        },
        { "type": "null" }
      ]
    },
    "error_message": {
      "type": ["string", "null"],
      "minLength": 1
    }
  },
  "required": [
    "schema_version",
    "run_id",
    "task_id",
    "job_id",
    "stage",
    "attempt",
    "execution_mode",
    "status",
    "created_at",
    "started_at",
    "completed_at",
    "inputs",
    "input_fingerprint",
    "task_spec_sha256",
    "candidate_outputs",
    "promoted_outputs",
    "validation_report_path",
    "error_code",
    "error_message"
  ],
  "allOf": [
    {
      "if": {
        "properties": {
          "schema_version": { "const": "1.1.0" },
          "stage": { "enum": ["draft", "review"] }
        },
        "required": ["schema_version", "stage"]
      },
      "then": {
        "required": ["document_id"],
        "properties": { "document_id": { "$ref": "#/$defs/documentId" } }
      }
    },
    {
      "if": {
        "properties": { "stage": { "not": { "enum": ["draft", "review"] } } },
        "required": ["stage"]
      },
      "then": { "properties": { "document_id": { "type": "null" } } }
    }
  ],
  "$defs": {
    "jobId": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9_.-]*$"
    },
    "runId": {
      "type": "string",
      "pattern": "^run_[0-9a-f]{32}$"
    },
    "taskId": {
      "type": "string",
      "pattern": "^task_[0-9a-f]{32}$"
    },
    "documentId": {
      "type": "string",
      "pattern": "^document_[0-9a-f]{32}$"
    },
    "stageName": {
      "enum": [
        "intake",
        "evidence",
        "parse",
        "confirm",
        "match",
        "decide",
        "brief",
        "draft",
        "review",
        "package_review",
        "package",
        "verify",
        "render"
      ]
    },
    "jobPath": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(?!/)(?![A-Za-z]:)(?!.*(?:^|/)\\.{1,2}(?:/|$))(?!.*\\\\)(?!.*//)(?!.*\/$)[^/]+(?:/[^/]+)*$"
    },
    "sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "artifactFingerprint": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "path": { "$ref": "#/$defs/jobPath" },
        "sha256": { "$ref": "#/$defs/sha256" },
        "size_bytes": {
          "type": ["integer", "null"],
          "minimum": 0
        }
      },
      "required": ["path", "sha256", "size_bytes"]
    }
  }
}
