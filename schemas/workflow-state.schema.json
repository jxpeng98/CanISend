{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/jxpeng98/CanISend/schemas/workflow-state.schema.json",
  "title": "CanISendWorkflowStateV1",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "schema_version": { "enum": ["1.0.0", "1.1.0"], "default": "1.1.0" },
    "job_id": { "$ref": "#/$defs/jobId" },
    "revision": { "type": "integer", "minimum": 0 },
    "created_at": { "type": "string", "format": "date-time" },
    "updated_at": { "type": "string", "format": "date-time" },
    "active_run_id": {
      "oneOf": [
        { "$ref": "#/$defs/runId" },
        { "type": "null" }
      ]
    },
    "stages": {
      "type": "array",
      "items": { "$ref": "#/$defs/stageRecord" },
      "uniqueItems": true
    }
  },
  "required": [
    "schema_version",
    "job_id",
    "revision",
    "created_at",
    "updated_at",
    "active_run_id",
    "stages"
  ],
  "allOf": [
    {
      "if": {
        "properties": { "schema_version": { "const": "1.1.0" } },
        "required": ["schema_version"]
      },
      "then": {
        "properties": {
          "stages": {
            "items": {
              "if": {
                "properties": {
                  "stage": { "enum": ["draft", "review"] },
                  "status": {
                    "enum": ["running", "succeeded", "failed", "stale", "cancelled"]
                  }
                },
                "required": ["stage", "status"]
              },
              "then": {
                "required": ["document_id"],
                "properties": { "document_id": { "$ref": "#/$defs/documentId" } }
              }
            }
          }
        }
      }
    }
  ],
  "$defs": {
    "jobId": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9_.-]*$"
    },
    "runId": {
      "type": "string",
      "pattern": "^run_[0-9a-f]{32}$"
    },
    "documentId": {
      "type": "string",
      "pattern": "^document_[0-9a-f]{32}$"
    },
    "jobPath": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(?!/)(?![A-Za-z]:)(?!.*(?:^|/)\\.{1,2}(?:/|$))(?!.*\\\\)(?!.*//)(?!.*\/$)[^/]+(?:/[^/]+)*$"
    },
    "sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "artifactFingerprint": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "path": { "$ref": "#/$defs/jobPath" },
        "sha256": { "$ref": "#/$defs/sha256" },
        "size_bytes": {
          "type": ["integer", "null"],
          "minimum": 0
        }
      },
      "required": ["path", "sha256", "size_bytes"]
    },
    "stageName": {
      "enum": [
        "intake",
        "evidence",
        "parse",
        "confirm",
        "match",
        "decide",
        "brief",
        "draft",
        "review",
        "package_review",
        "package",
        "verify",
        "render"
      ]
    },
    "stageRecord": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "stage": { "$ref": "#/$defs/stageName" },
        "document_id": {
          "oneOf": [
            { "$ref": "#/$defs/documentId" },
            { "type": "null" }
          ],
          "default": null
        },
        "status": {
          "enum": [
            "pending",
            "blocked",
            "ready",
            "running",
            "succeeded",
            "failed",
            "stale",
            "cancelled"
          ]
        },
        "attempt_count": { "type": "integer", "minimum": 0 },
        "run_id": {
          "oneOf": [
            { "$ref": "#/$defs/runId" },
            { "type": "null" }
          ]
        },
        "input_fingerprint": {
          "oneOf": [
            { "$ref": "#/$defs/sha256" },
            { "type": "null" }
          ]
        },
        "inputs": {
          "type": "array",
          "items": { "$ref": "#/$defs/artifactFingerprint" },
          "uniqueItems": true
        },
        "outputs": {
          "type": "array",
          "items": { "$ref": "#/$defs/artifactFingerprint" },
          "uniqueItems": true
        },
        "started_at": {
          "oneOf": [
            { "type": "string", "format": "date-time" },
            { "type": "null" }
          ]
        },
        "completed_at": {
          "oneOf": [
            { "type": "string", "format": "date-time" },
            { "type": "null" }
          ]
        },
        "error_code": {
          "oneOf": [
            {
              "type": "string",
              "pattern": "^[a-z][a-z0-9_-]*(\\.[a-z][a-z0-9_-]*)+$"
            },
            { "type": "null" }
          ]
        }
      },
      "required": [
        "stage",
        "status",
        "attempt_count",
        "run_id",
        "input_fingerprint",
        "inputs",
        "outputs",
        "started_at",
        "completed_at",
        "error_code"
      ],
      "allOf": [
        {
          "if": {
            "properties": { "stage": { "not": { "enum": ["draft", "review"] } } },
            "required": ["stage"]
          },
          "then": { "properties": { "document_id": { "type": "null" } } }
        }
      ]
    }
  }
}
